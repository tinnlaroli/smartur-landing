---
import Button from "./Button.astro";
import type { Link } from "../types";

// interface Stat {
//   number: string;
//   suffix: string;
//   label: string;
// }

interface Slide {
  id: string;       // "mission" | "vision" | "values"
  label: string;
  text: string;
}

interface Props {
  id?: string;
  title: string;
  subtitle?: string;
  sectionLabel: string;
  award: string;
  awardBadge: string;
  awardYear?: string;
  slides: Slide[];
  description: string;
  // stats: Stat[]; removed
  cta?: Link;
  timelineTitle?: string;
  timelineItems?: {
    title: string;
    text: string;
  }[];
}

const {
  id = "about",
  title,
  subtitle,
  sectionLabel,
  award,
  awardBadge,
  awardYear = "2024",
  slides,
  description,
  // stats, removed
  cta,
  timelineTitle,
  timelineItems,
} = Astro.props;
---

<section class="sy-about" id={id}>
  <div class="u-container">
    <!-- Editorial Two-Column Layout -->
    <div class="editorial-grid">
      <!-- Left Column: Main Content (60%) -->
      <div class="content-column">
        <div class="section-label" data-sy-reveal="">
          <span class="label-line"></span>
          <span class="label-text" set:html={sectionLabel} />
        </div>

        <h2 class="editorial-title sy-kinetic-heading" data-sy-reveal="" set:html={title} />

        {
          subtitle ? (
            <p class="editorial-subtitle" data-sy-reveal="lines" set:html={subtitle} />
          ) : null
        }

        <!-- Award Badge - Minimal Seal Style -->
        <div class="award-seal" data-sy-reveal="">
          <div class="seal-badge">
            <svg
              class="seal-icon"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"
              ></path>
            </svg>
            <span class="seal-text" set:html={awardBadge} />
          </div>
          <div class="award-info">
            <h3 class="award-name" set:html={award} />
            <span class="award-year">{awardYear}</span>
          </div>
        </div>

        <!-- Mission/Vision/Values Cycling Statement -->
        <div class="mission-carousel" id="mission-carousel">
          {slides.map((slide, i) => (
            <div class={`mission-slide ${i === 0 ? 'active' : ''}`} data-slide={slide.id}>
              <h3 class="mission-label" set:html={slide.label} />
              <p class="mission-text" set:html={slide.text} />
            </div>
          ))}
        </div>

        {cta ? <Button {...cta} arrow class="cta-button" /> : null}
      </div>

      <!-- Right Column: Stepper Timeline -->
      <div class="stepper-column">
        {timelineItems && (
          <div class="stepper-wrapper">
            <!-- Title removed as requested -->
            <div class="items-wrapper">
              <div class="items">
                {timelineItems.map((item, i) => (
                  <div class:list={["step-item", i === 0 && "is-active"]}>
                    <div class="item-inner">
                      <h3 class="step-title" set:html={item.title} />
                      <p class="step-text">{item.text}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .sy-about {
    padding: 8rem 0 3rem;
    position: relative;
    background: var(--color-bg);
    min-height: 100dvh; /* Restored to ensure pinning occupies full screen */
    display: flex;
    align-items: center;

    @media (--mq-tablet) {
      padding: 5rem 0 3rem;
    }

    @media (--mq-phone) {
      padding: 3rem 0 2rem;
    }
  }

  /* Editorial Grid Layout */
  .editorial-grid {
    display: grid;
    grid-template-columns: 1fr 1fr; /* Restore 2 columns */
    gap: 4rem;
    align-items: start;
    position: relative; /* Context for sticky */

    @media (--mq-desktop-lg) {
      gap: 3rem;
    }

    @media (--mq-tablet) {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
  }

  /* Section Label */
  .section-label {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.6s var(--ease-out-cubic);

    &.is-in {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .label-line {
    width: 3rem;
    height: 2px;
    background: var(--color-purple);
  }

  .label-text {
    font-family: var(--font-family-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-purple);
  }

  /* Editorial Title - Large Format */
  .editorial-title {
    font-family: var(--font-family-heading);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0 0 1.5rem 0;
    max-width: 20ch;

    @media (--mq-phone) {
      font-size: 2.25rem;
    }
  }

  .editorial-subtitle {
    font-family: var(--font-family-body);
    font-size: 1.125rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-alt);
    margin: 0 0 3rem 0;
    max-width: 60ch;
  }

  /* Award Seal - Minimal & Elegant */
  .award-seal {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    margin: 3rem 0;
    padding: 0;
    border: none;
    background: none;
  }

  .seal-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .seal-icon {
    width: 2.5rem;
    height: 2.5rem;
    color: var(--color-green);
    stroke-width: 1.5;
  }

  .seal-text {
    font-family: var(--font-family-body);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-green);
  }

  .award-info {
    flex: 1;
    padding-top: 0.25rem;
  }

  .award-name {
    font-family: var(--font-family-body);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-text);
    margin: 0 0 0.25rem 0;
  }

  .award-year {
    font-family: var(--font-family-heading);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text-alt);
  }

  /* Mission/Vision/Values Carousel */
  .mission-carousel {
    display: grid;
    grid-template-columns: 1fr;
    margin: 1.5rem 0;
  }

  .mission-slide {
    grid-area: 1 / 1; 
    width: 100%;
    padding-left: 2rem;
    border-left: 2px solid var(--color-purple);
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.6s ease, transform 0.6s ease;
    pointer-events: none;
    
    &.active {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
      z-index: 1;
    }

    &[data-slide="mission"] {
      border-left-color: var(--color-green);
      .mission-label { color: var(--color-green); }
    }

    &[data-slide="vision"] {
      border-left-color: var(--color-purple);
      .mission-label { color: var(--color-purple); }
    }

    &[data-slide="values"] {
      border-left-color: var(--color-pink);
      .mission-label { color: var(--color-pink); }
    }
  }

  .mission-label {
    font-family: var(--font-family-body);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-purple);
    margin: 0 0 1rem 0;
  }

  .mission-text {
    font-family: var(--font-family-body);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.7;
    color: var(--color-text);
    margin: 0;
    max-width: 55ch;
  }

  .cta-button {
    margin-top: 1rem;
  }


  /* Stepper / Timeline Styles (Restored) */
  .stepper-column {
    display: flex;
    flex-direction: column;
    justify-content: center;

    @media (--mq-phone) {
      margin-top: 2rem;
    }
  }

  .stepper-wrapper {
    /* Container for the sticky content */
  }

  .items-wrapper {
    display: flex;
    padding-left: 2rem; /* Reduced from original 4rem for column fit */
    position: relative;
    
    @media (--mq-phone) {
      padding-left: 0.5rem; /* Tighter on mobile */
    }

    &::before {
      content: "";
      display: block;
      min-height: 100%;
      min-width: 2px; /* Thin line */
      margin-right: 2rem;
      background: rgba(var(--rgb-text), 0.1); 
      border-radius: 0;
      
      @media (--mq-phone) {
        margin-right: 1.5rem; /* Tighter gap */
      }
    }
  }

  .items {
    display: flex;
    flex-direction: column;

    @media (--mq-phone) {
      gap: 1.5rem;
      padding-bottom: 2rem;
    }
  }

  .step-item {
    transition: opacity 0.6s var(--ease-out-cubic);
    opacity: 0.3;
    position: relative;
    padding-right: 2rem; /* Buffer from the line on desktop */
    
    &.is-active {
      opacity: 1;
    }

    @media (--mq-phone) {
      padding: 1.5rem;
      padding-right: 1.5rem;
      
      /* Premium Card Styling for Mobile */
      background: rgba(var(--rgb-bg-alt), 0.8);
      border-radius: 1rem;
      border: 1px solid rgba(var(--rgb-text), 0.08);
      box-shadow: 0 10px 30px rgba(var(--rgb-text), 0.05);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      
      /* Scaling logic for non-active cards */
      transform: scale(0.98);
      transition: opacity 0.6s var(--ease-out-cubic), transform 0.6s var(--ease-out-cubic), border-color 0.4s ease;

      &.is-active {
        transform: scale(1);
        border-color: rgba(var(--rgb-purple), 0.5);
      }
    }
  }

  .item-inner {
    display: flex;
    position: relative;
    flex-direction: column;
    gap: 0.5rem;
    padding: 2rem 0;

    @media (--mq-phone) {
      padding: 0;
    }

    /* The number indicator */
    &::before {
      content: '';
      position: absolute;
      right: calc(100% + 2rem - 5px); /* Center on the 2px line */
      top: 2.5rem; /* Optical alignment with title */
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: var(--color-bg);
      border: 2px solid var(--color-text-alt);
      z-index: 1;
      transition: all 0.4s ease;

      @media (--mq-phone) {
        /* Move dot to the left vertical line */
        /* Distance = padding of card + margin of line = 1.5rem + 1.5rem = 3rem. Plus half of 12px width = 6px */
        left: calc(-3rem - 6px); 
        top: 0.25rem;
        right: auto;
        transform: none;
      }
    }

    /* Active state for the dot */
    :global(.step-item.is-active &) {
      &::before {
        background: var(--color-purple);
        border-color: var(--color-purple);
        transform: scale(1.2);
        box-shadow: 0 0 0 4px rgba(var(--rgb-purple), 0.2);
      }
    }
  }

  .step-title {
    font-family: var(--font-family-body);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .step-text {
    font-family: var(--font-family-body);
    font-size: 0.875rem;
    color: var(--color-text-alt);
    line-height: 1.6;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const carousel = document.getElementById('mission-carousel');
  if (carousel) {
    const slides = carousel.querySelectorAll('.mission-slide');
    let current = 0;

    setInterval(() => {
      slides[current].classList.remove('active');
      current = (current + 1) % slides.length;
      slides[current].classList.add('active');
    }, 6000);
  }

  // Stepper Logic
  const initStepper = () => {
    const items = document.querySelectorAll('.step-item');
    if (items.length === 0) return;

    // Apply ScrollTrigger animation across all devices
    ScrollTrigger.create({
      trigger: ".sy-about", // Use the section as trigger
      start: "top top", 
      end: () => `+=${window.innerHeight * (window.innerWidth < 1024 ? 2.5 : 3)}`, // Give enough scroll distance for the cards to transition cleanly
      pin: true, 
      scrub: true, 
      onUpdate: (self) => {
        const total = items.length;
        const index = Math.min(
            Math.floor(self.progress * total), 
            total - 1
        );
        
        items.forEach((item, i) => {
            if (i === index) {
                item.classList.add('is-active');
            } else {
                item.classList.remove('is-active');
            }
        });
      }
    });
  };

  initStepper();
  document.addEventListener('astro:page-load', initStepper);
</script>

