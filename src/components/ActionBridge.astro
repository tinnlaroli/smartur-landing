---
import { ui } from "../i18n/ui";
import { ArrowRight, Building2, Map, ExternalLink } from "lucide-react";

interface Props {
  lang?: keyof typeof ui;
}

const { lang = "es" } = Astro.props;
const t = ui[lang];
---

<section class="action-bridge-section relative z-20 py-12 md:py-20 lg:py-24">
  <div class="container mx-auto px-4">
    <div class="bridge-card relative p-4 md:p-8 text-center max-w-5xl mx-auto">
      
      <div class="relative z-10 flex flex-col md:flex-row gap-6 md:gap-8 justify-center items-center">
        
        {/* Business CTA (Primary) */}
        <a href="#pricing" class="bridge-action group relative w-full md:w-auto min-w-[320px] shadow-xl hover:shadow-2xl p-4 rounded-[2rem] transition-all duration-300 hover:-translate-y-1">
          <div class="flex items-center gap-5">
            <div class="icon-box w-16 h-16 shrink-0 rounded-full flex items-center justify-center transition-transform duration-300 group-hover:scale-110">
              <Building2 size={32} />
            </div>
            <div class="text-left flex-grow min-w-0">
              <span class="bridge-label block text-xl font-bold transition-colors">{t["action.business.label"]}</span>
              <div class="grid grid-rows-[0fr] group-hover:grid-rows-[1fr] transition-[grid-template-rows] duration-300 ease-out">
                <span class="bridge-desc overflow-hidden text-sm font-medium block pt-1">
                  {t["action.business.description"]}
                </span>
              </div>
            </div>
            <div class="action-arrow w-10 h-10 rounded-full flex items-center justify-center transition-colors">
              <ArrowRight className="w-5 h-5 transition-colors" />
            </div>
          </div>
        </a>

        {/* Separator (Mobile: Hidden, Desktop: Visible) */}
        <div class="hidden md:block w-px h-12 bg-slate-200/50"></div>

        {/* Tourist CTA (Secondary) */}
        <a href="https://app.smartur.com" target="_blank" rel="noopener noreferrer" class="bridge-action group relative w-full md:w-auto min-w-[320px] shadow-xl hover:shadow-2xl p-4 rounded-[2rem] transition-all duration-300 hover:-translate-y-1">
          <div class="flex items-center gap-5">
            <div class="icon-box-tourist w-16 h-16 shrink-0 rounded-full flex items-center justify-center transition-transform duration-300 group-hover:scale-110">
              <Map size={32} />
            </div>
            <div class="text-left flex-grow min-w-0">
              <span class="bridge-label-tourist block text-xl font-bold transition-colors">{t["action.tourist.label"]}</span>
               <div class="grid grid-rows-[0fr] group-hover:grid-rows-[1fr] transition-[grid-template-rows] duration-300 ease-out">
                <span class="bridge-desc overflow-hidden text-sm font-medium block pt-1">
                  {t["action.tourist.description"]}
                </span>
              </div>
            </div>
            <div class="action-arrow-tourist w-10 h-10 rounded-full flex items-center justify-center transition-colors">
              <ExternalLink className="w-5 h-5 transition-colors" />
            </div>
          </div>
        </a>

      </div>
    </div>
  </div>
</section>

<style>
  /* ─── Styles for ActionBridge ─── */

  /* DEFAULT LIGHT MODE */
  .bridge-action {
    background-color: #ffffff;
    border: 1px solid #e2e8f0; /* slate-200 */
  }

  /* Business/Primary Items */
  .icon-box {
    background-color: #f6eafe; /* purple-50 approx */
    color: #9333ea; /* purple-600 */
  }
  
  .bridge-action:hover .icon-box {
    background-color: #f3e8ff; /* purple-100 */
  }

  .bridge-label {
    color: #0f172a; /* slate-900 */
  }
  
  .bridge-action:hover .bridge-label {
    color: #7e22ce; /* purple-700 */
  }

  .bridge-desc {
    color: #64748b; /* slate-500 */
  }

  .action-arrow {
    background-color: #f8fafc; /* slate-50 */
  }
  
  .action-arrow svg {
    color: #94a3b8; /* slate-400 */
  }

  .bridge-action:hover .action-arrow {
    background-color: #a855f7; /* purple-500 */
  }
  
  .bridge-action:hover .action-arrow svg {
    color: #ffffff;
  }

  /* Tourist/Secondary Items */
  .icon-box-tourist {
    background-color: #f8fafc; /* slate-50 */
    color: #475569; /* slate-600 */
  }

  .bridge-action:hover .icon-box-tourist {
    background-color: #f1f5f9; /* slate-100 */
  }

  .bridge-label-tourist {
    color: #0f172a; /* slate-900 */
  }

  .bridge-action:hover .bridge-label-tourist {
    color: #334155; /* slate-700 */
  }

  .action-arrow-tourist {
    background-color: #f8fafc; /* slate-50 */
  }

  .action-arrow-tourist svg {
    color: #94a3b8; /* slate-400 */
  }

  .bridge-action:hover .action-arrow-tourist {
    background-color: #1e293b; /* slate-800 */
  }

  .bridge-action:hover .action-arrow-tourist svg {
    color: #ffffff;
  }


  /* DARK MODE OVERRIDES */
  :global([data-theme="dark"]) .bridge-action {
    background-color: var(--color-bg-alt);
    border-color: rgba(255, 255, 255, 0.1);
  }

  /* Business Dark */
  :global([data-theme="dark"]) .icon-box {
    background-color: rgba(88, 28, 135, 0.2); /* purple-900/20 */
    color: #c084fc; /* purple-400 */
  }

  :global([data-theme="dark"]) .bridge-action:hover .icon-box {
    background-color: rgba(88, 28, 135, 0.4); /* purple-900/40 */
  }

  :global([data-theme="dark"]) .bridge-label {
    color: #ffffff;
  }

  :global([data-theme="dark"]) .bridge-action:hover .bridge-label {
    color: #c084fc; /* purple-400 */
  }

  :global([data-theme="dark"]) .bridge-desc {
    color: #94a3b8; /* slate-400 */
  }

  :global([data-theme="dark"]) .action-arrow {
    background-color: #334155; /* slate-700 */
  }

  :global([data-theme="dark"]) .action-arrow svg {
    color: #cbd5e1; /* slate-300 */
  }

  /* Tourist Dark */
  :global([data-theme="dark"]) .icon-box-tourist {
    background-color: rgba(51, 65, 85, 0.5); /* slate-700/50 */
    color: #cbd5e1; /* slate-300 */
  }

  :global([data-theme="dark"]) .bridge-action:hover .icon-box-tourist {
    background-color: #334155; /* slate-700 */
  }

  :global([data-theme="dark"]) .bridge-label-tourist {
    color: #ffffff;
  }

  :global([data-theme="dark"]) .bridge-action:hover .bridge-label-tourist {
    color: #cbd5e1; /* slate-300 */
  }

  :global([data-theme="dark"]) .action-arrow-tourist {
    background-color: #334155; /* slate-700 */
  }

  :global([data-theme="dark"]) .action-arrow-tourist svg {
    color: #cbd5e1; /* slate-300 */
  }

  :global([data-theme="dark"]) .bridge-action:hover .action-arrow-tourist {
    background-color: #475569; /* slate-600 */
  }
</style>
