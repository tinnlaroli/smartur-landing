---
import { ui } from "../i18n/ui";
import circuitImg from "../assets/imgs/circuit.png";

interface Props {
  lang?: keyof typeof ui;
  id?: string;
}

const { lang = "es", id } = Astro.props;

const t = ui[lang];

const title = t["tech.title"];
const intro = t["tech.text"];
const features = [
  { title: t["tech.feature1.title"], description: t["tech.feature1.desc"] },
  { title: t["tech.feature2.title"], description: t["tech.feature2.desc"] },
  { title: t["tech.feature3.title"], description: t["tech.feature3.desc"] },
];

const chips =
  {
    es: [
      "Random Forest",
      "Collaborative Filtering",
      "Ranking por contexto",
      "Cold-start",
      "Seguridad de datos",
    ],
    en: [
      "Random Forest",
      "Collaborative Filtering",
      "Context-aware ranking",
      "Cold-start",
      "Data security",
    ],
    fr: [
      "Random Forest",
      "Filtrage collaboratif",
      "Classement par contexte",
      "Cold-start",
      "Sécurité des données",
    ],
  }[lang] ?? ["Random Forest", "Collaborative Filtering"];

const howTitle =
  { es: "Cómo funciona", en: "How it works", fr: "Comment ça marche" }[lang] ??
  "How it works";

const howSteps =
  {
    es: [
      {
        title: "Contexto",
        text: "Señales como ubicación, temporada, presupuesto e intención de viaje.",
      },
      {
        title: "Candidatos",
        text: "Generamos opciones relevantes con filtrado colaborativo + reglas de negocio.",
      },
      {
        title: "Re-ranking",
        text: "Random Forest prioriza lo más útil para ese usuario, en ese momento.",
      },
      {
        title: "Entrega",
        text: "Recomendaciones con precisión, diversidad y protección de datos.",
      },
    ],
    en: [
      {
        title: "Context",
        text: "Signals like location, season, budget, and travel intent.",
      },
      {
        title: "Candidates",
        text: "We generate relevant options with collaborative filtering + business rules.",
      },
      {
        title: "Re-ranking",
        text: "Random Forest prioritizes what’s most useful, right now.",
      },
      {
        title: "Delivery",
        text: "Recommendations with precision, diversity, and data protection.",
      },
    ],
    fr: [
      {
        title: "Contexte",
        text: "Signaux comme localisation, saison, budget et intention de voyage.",
      },
      {
        title: "Candidats",
        text: "Options pertinentes via filtrage collaboratif + règles métier.",
      },
      {
        title: "Re-classement",
        text: "Random Forest priorise ce qui est le plus utile maintenant.",
      },
      {
        title: "Livraison",
        text: "Recommandations précises, diversité maîtrisée, données protégées.",
      },
    ],
  }[lang] ?? [];

const uiCopy =
  {
    es: {
      eyebrow: "Recomendación técnica, experiencia elegante",
      panelTitle: "Panel de recomendación",
      panelSubtitle: "Señales + modelos → ranking final",
      kpi1: "Precisión",
      kpi2: "Diversidad",
      kpi3: "Cobertura",
      chart1: "Tendencia de calidad",
      chart2: "Impacto por señal",
      chart3: "Mix de modelos",
      signalsTitle: "Señales principales",
      signals: ["Ubicación", "Temporada", "Preferencias", "Historial", "Contexto"],
    },
    en: {
      eyebrow: "Technical recommendations, elegant experience",
      panelTitle: "Recommendation panel",
      panelSubtitle: "Signals + models → final ranking",
      kpi1: "Precision",
      kpi2: "Diversity",
      kpi3: "Coverage",
      chart1: "Quality trend",
      chart2: "Signal impact",
      chart3: "Model mix",
      signalsTitle: "Top signals",
      signals: ["Location", "Season", "Preferences", "History", "Context"],
    },
    fr: {
      eyebrow: "Recommandation technique, expérience élégante",
      panelTitle: "Panneau de recommandation",
      panelSubtitle: "Signaux + modèles → classement final",
      kpi1: "Précision",
      kpi2: "Diversité",
      kpi3: "Couverture",
      chart1: "Tendance qualité",
      chart2: "Impact des signaux",
      chart3: "Mix des modèles",
      signalsTitle: "Signaux principaux",
      signals: [
        "Localisation",
        "Saison",
        "Préférences",
        "Historique",
        "Contexte",
      ],
    },
  }[lang] ?? {
    eyebrow: "Recommendation system",
    panelTitle: "Recommendation panel",
    panelSubtitle: "Signals + models → final ranking",
    kpi1: "Precision",
    kpi2: "Diversity",
    kpi3: "Coverage",
    chart1: "Quality trend",
    chart2: "Signal impact",
    chart3: "Model mix",
    signalsTitle: "Top signals",
    signals: ["Location", "Season", "Preferences", "History", "Context"],
  };
---

<section class="sy-tech" id={id}>
  <div
    class="circuit-bg"
    aria-hidden="true"
    style={`background-image: url(${circuitImg.src});`}
  ></div>

  <div class="u-container container">
    <header class="header">
      <p class="eyebrow" data-sy-reveal="fade">
        <span class="eyebrow__dot" aria-hidden="true"></span>
        {uiCopy.eyebrow}
      </p>
      <h2 class="u-heading title sy-kinetic-heading" data-sy-reveal="" set:html={title} />
      <p class="u-text intro" data-sy-reveal="lines" set:html={intro} />
      <div class="chips" data-sy-reveal="fade" aria-label="Modelos y principios">
        {chips.map((chip) => (
          <span class="chip">{chip}</span>
        ))}
      </div>
    </header>

    <div class="grid">
      <div class="left">
        <section class="how" aria-label={howTitle}>
          <h3 class="u-heading how-title" data-sy-reveal="fade">
            {howTitle}
          </h3>

          <ol class="flow">
            {howSteps.map((step, index) => (
              <li
                class="flow-item"
                data-sy-reveal="fade"
                style={`transition-delay: ${index * 0.08}s`}
              >
                <div class="flow-icon" aria-hidden="true">
                  {
                    [
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.7"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M12 2a8 8 0 0 0-8 8v3a3 3 0 0 0 3 3h2l3 6 3-6h2a3 3 0 0 0 3-3v-3a8 8 0 0 0-8-8Z"></path>
                        <path d="M9 10h.01"></path>
                        <path d="M15 10h.01"></path>
                      </svg>,
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.7"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M20 7h-9"></path>
                        <path d="M14 17H5"></path>
                        <circle cx="17" cy="17" r="3"></circle>
                        <circle cx="7" cy="7" r="3"></circle>
                      </svg>,
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.7"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M4 6h16"></path>
                        <path d="M7 12h10"></path>
                        <path d="M10 18h4"></path>
                      </svg>,
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.7"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M22 12l-4 4-2-2-4 4-6-6-4 4"></path>
                        <path d="M22 8v4h-4"></path>
                      </svg>,
                    ][index]
                  }
                </div>

                <div class="flow-body">
                  <div class="flow-top">
                    <div class="flow-badge" aria-hidden="true">
                      {String(index + 1).padStart(2, "0")}
                    </div>
                    <p class="u-text flow-title">{step.title}</p>
                  </div>
                  <p class="u-text flow-text">{step.text}</p>
                </div>
              </li>
            ))}
          </ol>
        </section>

        <section class="features" aria-label="Beneficios">
          {features.map((feature, index) => (
            <article
              class="feature-card"
              data-sy-reveal="fade"
              style={`transition-delay: ${index * 0.12}s`}
            >
              <div class="feature-head">
                <span class="feature-icon" aria-hidden="true">
                  {
                    [
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.7"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M21 16V8"></path>
                        <path d="M18 16V8"></path>
                        <path d="M3 16V8"></path>
                        <path d="M6 16V8"></path>
                        <path d="M9 12h6"></path>
                      </svg>,
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.7"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M3 7h18"></path>
                        <path d="M6 7v14"></path>
                        <path d="M18 7v14"></path>
                        <path d="M9 11h6"></path>
                        <path d="M9 15h6"></path>
                      </svg>,
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.7"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M12 1l3 5h6l-3 5 3 5h-6l-3 5-3-5H3l3-5-3-5h6z"></path>
                      </svg>,
                    ][index]
                  }
                </span>
                <h3 class="u-heading feature-title" set:html={feature.title} />
              </div>
              <p class="u-text feature-description">{feature.description}</p>
            </article>
          ))}
        </section>
      </div>

      <aside class="panel" data-sy-reveal="fade" aria-label={uiCopy.panelTitle}>
        <header class="panel-header">
          <div class="panel-title">
            <span class="panel-badge" aria-hidden="true">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M4 19V5"></path>
                <path d="M4 15h16"></path>
                <path d="M20 19V5"></path>
                <path d="M8 11h8"></path>
              </svg>
            </span>
            <div>
              <p class="u-text panel-h">{uiCopy.panelTitle}</p>
              <p class="u-text panel-sub">{uiCopy.panelSubtitle}</p>
            </div>
          </div>

          <div class="kpis" role="list" aria-label="Indicadores">
            {[
              { label: uiCopy.kpi1, value: "0.92" },
              { label: uiCopy.kpi2, value: "0.74" },
              { label: uiCopy.kpi3, value: "0.88" },
            ].map((kpi) => (
              <div class="kpi" role="listitem">
                <p class="u-text kpi-label">{kpi.label}</p>
                <p class="u-heading kpi-value">{kpi.value}</p>
              </div>
            ))}
          </div>
        </header>

        <div class="panel-grid">
          <section class="card">
            <div class="card-top">
              <p class="u-text card-title">{uiCopy.chart1}</p>
              <span class="pill pill--ok">stable</span>
            </div>
            <svg
              class="spark"
              viewBox="0 0 240 64"
              width="100%"
              height="64"
              aria-hidden="true"
            >
              <defs>
                <linearGradient id="sySpark" x1="0" y1="0" x2="1" y2="0">
                  <stop
                    offset="0%"
                    stop-color="rgb(var(--rgb-purple-accent))"
                  />
                  <stop
                    offset="55%"
                    stop-color="rgb(var(--rgb-cyan-accent))"
                  />
                  <stop offset="100%" stop-color="rgb(var(--rgb-pink-primary))" />
                </linearGradient>
              </defs>
              <path
                d="M2 50 C 24 54, 30 30, 50 34 C 70 38, 78 12, 98 16 C 118 20, 126 30, 146 26 C 166 22, 178 10, 198 14 C 216 18, 222 26, 238 20"
                fill="none"
                stroke="url(#sySpark)"
                stroke-width="3"
                stroke-linecap="round"
              />
              <path
                d="M2 50 C 24 54, 30 30, 50 34 C 70 38, 78 12, 98 16 C 118 20, 126 30, 146 26 C 166 22, 178 10, 198 14 C 216 18, 222 26, 238 20 L 238 64 L 2 64 Z"
                fill="rgba(var(--rgb-purple-accent), 0.08)"
              />
            </svg>
          </section>

          <section class="card">
            <div class="card-top">
              <p class="u-text card-title">{uiCopy.chart2}</p>
              <span class="pill">top-5</span>
            </div>
            <div class="bars" aria-hidden="true">
              {[76, 62, 54, 41, 33].map((h, i) => (
                <div class="bar" style={`--h:${h}%`} data-i={i}></div>
              ))}
            </div>
            <div class="legend">
              {uiCopy.signals.map((s, i) => (
                <span class="legend-item" title={s}>
                  <span class="legend-dot" data-i={i} aria-hidden="true"></span>
                  {s}
                </span>
              ))}
            </div>
          </section>

          <section class="card card--mix">
            <div class="card-top">
              <p class="u-text card-title">{uiCopy.chart3}</p>
              <span class="pill">RF + CF</span>
            </div>
            <div class="mix">
              <div
                class="donut"
                aria-hidden="true"
                style="--p1:58; --p2:27; --p3:15;"
              ></div>
              <div class="mix-legend" aria-hidden="true">
                <div class="mix-row">
                  <span class="mix-dot mix-dot--1"></span> Random Forest
                </div>
                <div class="mix-row">
                  <span class="mix-dot mix-dot--2"></span> Collaborative
                </div>
                <div class="mix-row">
                  <span class="mix-dot mix-dot--3"></span> Reglas
                </div>
              </div>
            </div>
          </section>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .sy-tech {
    position: relative;
    padding: 8rem 0;
    background: rgba(var(--rgb-purple-accent), 0.04);
    overflow: hidden;

    @media (--mq-tablet) {
      padding: 6rem 0;
    }

    @media (--mq-phone) {
      padding: 4.5rem 0;
    }
  }

  .circuit-bg {
    position: absolute;
    inset: 0;
    background-repeat: repeat;
    background-size: 110px;
    opacity: 0.028;
    pointer-events: none;
  }

  .container {
    position: relative;
    z-index: 2;
  }

  .header {
    text-align: center;
    max-width: 56rem;
    margin: 0 auto 3.5rem;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin: 0 auto 0.9rem;
    padding: 0.45rem 0.75rem;
    width: fit-content;
    border-radius: 999px;
    background: rgba(var(--rgb-bg), 0.7);
    border: 1px solid rgba(var(--rgb-text), 0.08);
    color: var(--color-text);
    font-size: 0.82rem;
    letter-spacing: 0.01em;
  }

  .eyebrow__dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: linear-gradient(
      135deg,
      rgb(var(--rgb-purple-accent)) 0%,
      rgb(var(--rgb-cyan-accent)) 100%
    );
    box-shadow: 0 0 0 4px rgba(var(--rgb-purple-accent), 0.08);
  }

  .title {
    --fs: 3.1rem;
    --lh: 1.1;
    margin-bottom: 1rem;
    color: var(--color-text);

    @media (--mq-phone) {
      --fs: 2.5rem;
    }
  }

  .intro {
    --fs: var(--font-size-lg);
    color: var(--color-text-alt);
    line-height: 1.7;
    max-width: 62ch;
    margin: 0.25rem auto 0;
  }

  .chips {
    margin-top: 1.25rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    background: rgba(var(--rgb-bg), 0.75);
    border: 1px solid rgba(var(--rgb-text), 0.08);
    color: var(--color-text);
    font-size: 0.82rem;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }

  .grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 2.25rem;
    align-items: start;

    @media (--mq-tablet) {
      grid-template-columns: 1fr;
    }
  }

  .left {
    display: grid;
    gap: 1.25rem;
  }

  .how {
    border-radius: 1.5rem;
    padding: 1.5rem;
    background: rgba(var(--rgb-bg), 0.6);
    border: 1px solid rgba(var(--rgb-text), 0.08);
    box-shadow: 0 16px 44px rgba(var(--rgb-text), 0.04);
  }

  .how-title {
    --fs: 1.05rem;
    --fw: 800;
    margin: 0 0 1rem;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .flow {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.75rem;
  }

  .flow-item {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 1rem;
    align-items: start;
    padding: 0.9rem 0.95rem;
    border-radius: 1.1rem;
    border: 1px solid rgba(var(--rgb-text), 0.06);
    background: rgba(var(--rgb-bg), 0.72);
    transition:
      border-color 0.25s var(--ease-standard),
      transform 0.25s var(--ease-standard),
      box-shadow 0.25s var(--ease-standard);

    &:hover {
      transform: translateY(-2px);
      border-color: rgba(var(--rgb-purple-accent), 0.22);
      box-shadow: 0 14px 38px rgba(var(--rgb-purple-accent), 0.08);
    }
  }

  .flow-icon {
    width: 3rem;
    height: 3rem;
    border-radius: 1rem;
    display: grid;
    place-items: center;
    color: var(--color-purple);
    background: rgba(var(--rgb-purple-accent), 0.1);
    border: 1px solid rgba(var(--rgb-purple-accent), 0.18);

    svg {
      width: 20px;
      height: 20px;
      opacity: 0.95;
    }
  }

  .flow-top {
    display: flex;
    align-items: baseline;
    gap: 0.65rem;
    margin-bottom: 0.25rem;
  }

  .flow-badge {
    font-family: var(--font-family-heading);
    font-weight: 800;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--color-text-alt);
  }

  .flow-title {
    --fs: 0.95rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }

  .flow-text {
    --fs: 0.88rem;
    color: var(--color-text-alt);
    line-height: 1.6;
    margin: 0;
  }

  .features {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .feature-card {
    background: rgba(var(--rgb-bg), 0.7);
    border-radius: 1.25rem;
    padding: 1.5rem;
    border: 1px solid rgba(var(--rgb-purple-accent), 0.22);
    box-shadow: 0 10px 30px rgba(var(--rgb-text), 0.04);
    transition:
      border-color 0.25s var(--ease-standard),
      box-shadow 0.25s var(--ease-standard),
      transform 0.25s var(--ease-standard);

    &:hover {
      transform: translateY(-4px);
      box-shadow: 0 14px 44px rgba(var(--rgb-purple-accent), 0.12);
      border-color: rgba(var(--rgb-purple-accent), 0.35);
    }
  }

  .feature-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.35rem;
  }

  .feature-icon {
    width: 36px;
    height: 36px;
    border-radius: 0.9rem;
    background: rgba(var(--rgb-cyan-accent), 0.1);
    border: 1px solid rgba(var(--rgb-cyan-accent), 0.18);
    display: grid;
    place-items: center;
    color: var(--color-cyan);

    svg {
      width: 18px;
      height: 18px;
    }
  }

  .feature-card:nth-child(1) .feature-icon {
    background: rgba(var(--rgb-purple-accent), 0.1);
    border-color: rgba(var(--rgb-purple-accent), 0.18);
    color: var(--color-purple);
  }

  .feature-card:nth-child(2) .feature-icon {
    background: rgba(var(--rgb-cyan-accent), 0.1);
    border-color: rgba(var(--rgb-cyan-accent), 0.18);
    color: var(--color-cyan);
  }

  .feature-card:nth-child(3) .feature-icon {
    background: rgba(var(--rgb-green-accent), 0.1);
    border-color: rgba(var(--rgb-green-accent), 0.18);
    color: var(--color-green);
  }

  .feature-title {
    --fs: 1.15rem;
    --fw: 700;
    margin: 0;
    color: var(--color-purple);
  }

  .feature-description {
    --fs: var(--font-size-sm);
    color: var(--color-text-alt);
    line-height: 1.65;
  }

  /* ── Right Panel (Dashboard) ───────────────────────────────────────────── */
  .panel {
    position: sticky;
    top: 7.5rem;
    border-radius: 1.75rem;
    padding: 1.25rem;
    background: rgba(var(--rgb-bg), 0.65);
    border: 1px solid rgba(var(--rgb-text), 0.08);
    box-shadow:
      0 20px 60px rgba(var(--rgb-text), 0.06),
      0 8px 24px rgba(var(--rgb-purple-accent), 0.06);
    backdrop-filter: blur(18px) saturate(1.2);
    -webkit-backdrop-filter: blur(18px) saturate(1.2);

    @media (--mq-tablet) {
      position: relative;
      top: auto;
    }
  }

  .panel-header {
    display: grid;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .panel-title {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .panel-badge {
    width: 44px;
    height: 44px;
    border-radius: 1.1rem;
    display: grid;
    place-items: center;
    background: linear-gradient(
      135deg,
      rgba(var(--rgb-purple-accent), 0.14) 0%,
      rgba(var(--rgb-cyan-accent), 0.14) 100%
    );
    border: 1px solid rgba(var(--rgb-text), 0.08);
    color: var(--color-text);
  }

