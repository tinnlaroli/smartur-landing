---
import { ui } from "../i18n/ui";
import Button from "./Button.astro";

interface Props {
  lang?: keyof typeof ui;
}

const { lang = "es" } = Astro.props;
const t = ui[lang];
---

<div
  class="cta-minimal bg-[var(--color-bg)] transition-colors duration-300 py-16 sm:py-20 md:py-24 lg:py-32"
>
  <div class="container mx-auto px-4 sm:px-6 md:px-12 max-w-7xl">
    <div
      class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 lg:gap-24 items-center"
    >
      <div class="cta-content-left reveal-fade-up">
        <span
          class="block text-sm font-semibold tracking-widest uppercase text-[var(--color-purple)] mb-4"
        >
          {t["contact.cta.label"]}
        </span>
        <h2
          class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-[var(--color-text)] leading-tight"
        >
          {t["contact.cta.title"]}
        </h2>
      </div>

      {/* Right Column: Text & Input */}
      <div
        class="cta-content-right reveal-fade-up"
        style="animation-delay: 200ms;"
      >
        <p
          class="text-base sm:text-lg text-[var(--color-text-alt)] mb-6 sm:mb-8 leading-relaxed max-w-md"
        >
          {t["contact.cta.text"]}
        </p>

        <form
          class="flex flex-col sm:flex-row gap-4 items-stretch sm:items-center w-full max-w-lg"
          data-success-message={t["contact.form.success"]}
        >
          <input
            type="email"
            placeholder={t["contact.cta.emailPlaceholder"]}
            class="w-full flex-grow min-w-0 bg-[var(--color-bg-alt)] border border-[rgba(var(--rgb-text),0.12)] text-[var(--color-text)] rounded-full py-3 sm:py-4 px-4 sm:px-6 outline-none focus:ring-2 focus:ring-[var(--color-purple)] transition-all duration-300 ease-out placeholder:opacity-60"
            required
          />
          <Button
            type="submit"
            title={t["contact.cta.submit"]}
            color="primary-alt"
            arrow
            class="w-full sm:w-auto whitespace-nowrap shadow-md hover:-translate-y-0.5"
          />
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  // Simple intersection observer from original component, preserved for consistency
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    },
    {
      threshold: 0.1,
      rootMargin: "0px 0px -50px 0px",
    },
  );

  document.querySelectorAll(".reveal-fade-up").forEach((el) => {
    observer.observe(el);
  });

  // Form handling
  const forms = document.querySelectorAll(".cta-minimal form");
  forms.forEach((form) => {
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      console.log("CTA Form submitted");
      const successMessage =
        form.getAttribute("data-success-message") ||
        "Gracias. Nos pondremos en contacto pronto.";
      alert(successMessage);
      (form as HTMLFormElement).reset();
    });
  });
</script>

<style>
  .reveal-fade-up {
    opacity: 0;
    transform: translateY(30px);
    transition:
      opacity 0.8s cubic-bezier(0.2, 0.8, 0.2, 1),
      transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .reveal-fade-up.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
