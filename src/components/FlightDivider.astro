---
import { useTranslations } from "../i18n/utils";
import { ui } from "../i18n/ui";
import ActionBridge from "./ActionBridge.astro";

type Lang = keyof typeof ui;

interface Props {
  lang?: Lang;
}

const { lang = "es" } = Astro.props;
const t = useTranslations(lang);

// Translation keys for the divider text (2 lines)
const text: Record<Lang, string[]> = {
  es: ["TRANSFORMANDO EL", "CAMINO JUNTOS"],
  en: ["TRANSFORMING THE", "ROAD TOGETHER"],
  fr: ["TRANSFORMER LA", "ROUTE ENSEMBLE"],
};
---

<section
  id="flight-divider"
  class="relative flight-divider-section flight-divider-height"
>
  <!-- Clipped Container for Flight Path & Background Elements -->
  <div class="absolute inset-0 w-full h-full overflow-hidden pointer-events-none">
    
    <!-- Optional Tech/Travel Text (2 Lines) -->
    <div class="absolute top-[40%] left-1/2 -translate-x-1/2 -translate-y-1/2 text-center z-40 flight-text flex flex-col items-center justify-center leading-none">
        {text[lang].map((line, i) => (
            <div class={`flex space-x-2 md:space-x-4 ${i === 1 ? "mt-2 md:mt-4" : ""}`}>
                {line.split(" ").map((word) => (
                    <span class="inline-block whitespace-nowrap">
                        {word.split("").map((char) => (
                            <span class="inline-block text-4xl md:text-5xl lg:text-6xl font-black text-[var(--color-pink)] tracking-tighter relative z-20 uppercase drop-shadow-sm">
                                {char}
                            </span>
                        ))}
                    </span>
                ))}
            </div>
        ))}
    </div>

    <!-- Flight SVG Container -->
    <svg
      id="flight-svg"
      class="w-full h-full absolute inset-0 pointer-events-none"
      fill="none"
      preserveAspectRatio="none" 
      xmlns="http://www.w3.org/2000/svg"
    >
      <defs>
        <mask id="flight-mask">
            <path 
                id="flight-mask-path" 
                d="M -100, 800 C 300, 800, 200, 200, 600, 400 S 1200, 0, 1600, -100"
                stroke="white" 
                stroke-width="6" 
                fill="none" 
            />
        </mask>
      </defs>

      <!-- The defined flight path (invisible guide) -->
      <path
        id="flight-guide"
        class="opacity-0"
        d="M -100, 800 C 300, 800, 200, 200, 600, 400 S 1200, 0, 1600, -100"
        stroke="none"
      />
      
      <!-- The visible trail (Cyan Dotted) -->
      <path
        id="flight-trail"
        d="M -100, 800 C 300, 800, 200, 200, 600, 400 S 1200, 0, 1600, -100"
        stroke="#4DB9CA"
        stroke-width="5"
        stroke-dasharray="10 10"
        stroke-linecap="round"
        fill="none"
        mask="url(#flight-mask)"
        class="opacity-0 lg:opacity-100"
      />
    </svg>

    <!-- Paper Plane Element (hidden on phone for performance, shown tablet+) -->
    <div id="divider-plane" class="absolute top-0 left-0 z-10 w-60 h-60 origin-center divider-plane-el">
        <lottie-player
            src="/assets/paper-plane.json"
            background="transparent"
            speed="1"
            loop
            autoplay
            class="w-full h-full"
        ></lottie-player>
    </div>
  </div>

  <!-- ActionBridge - Outside overflowing container -->
  <div class="relative z-50 w-full h-full flex items-center justify-center pointer-events-none">
    <div class="pointer-events-auto translate-y-48 md:translate-y-50">
        <ActionBridge lang={lang} />
    </div>
  </div>
</section>

<script src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js"></script>

<script>
  import gsap from "gsap";

  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { MotionPathPlugin } from "gsap/MotionPathPlugin";

  gsap.registerPlugin(ScrollTrigger, MotionPathPlugin);

  const initFlightDivider = () => {
    const section = document.querySelector("#flight-divider") as HTMLElement;
    const plane = document.querySelector("#divider-plane");
    const trail = document.querySelector("#flight-trail") as SVGPathElement;
    const maskPath = document.querySelector("#flight-mask-path") as SVGPathElement;
    const guide = document.querySelector("#flight-guide") as SVGPathElement;
    const textSpans = document.querySelectorAll(".flight-text span span");
    const isMobile = window.matchMedia("(max-width: 767px)").matches;

    if (!section || !guide) return;

    const updatePath = () => {
        const width = window.innerWidth;
        const height = section.clientHeight;
        const pathString = `M ${-0.1 * width}, ${0.8 * height} 
                           C ${0.2 * width}, ${0.8 * height}, ${0.35 * width}, ${0.5 * height}, ${0.45 * width}, ${0.5 * height}
                           C ${0.55 * width}, ${0.5 * height}, ${0.6 * width}, ${0.2 * height}, ${0.5 * width}, ${0.2 * height}
                           C ${0.4 * width}, ${0.2 * height}, ${0.4 * width}, ${0.6 * height}, ${0.55 * width}, ${0.6 * height}
                           S ${0.8 * width}, ${0.1 * height}, ${1.1 * width}, ${0.1 * height}`;
        guide.setAttribute("d", pathString);
        if (trail) trail.setAttribute("d", pathString);
        if (maskPath) maskPath.setAttribute("d", pathString);
    };

    updatePath();
    window.addEventListener("resize", updatePath);

    // Allow GSAP animation universally, we will configure pinning inside the timeline setup

    if (plane) gsap.set(plane, { autoAlpha: 1, scale: 0.5 });
    if (maskPath) {
        const length = maskPath.getTotalLength();
        gsap.set(maskPath, { strokeDasharray: length, strokeDashoffset: length });
    }

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#flight-divider",
        start: isMobile ? "top bottom" : "center center",
        end: isMobile ? "bottom top" : "+=150%",
        pin: !isMobile,
        scrub: 1,
      }
    });

    tl.to(plane, {
      motionPath: {
        path: "#flight-guide",
        align: "#flight-guide",
        autoRotate: true,
        alignOrigin: [0.5, 0.5],
      },
      scale: 1.5,
      ease: "none",
      duration: 5
    }, 0);

    if (maskPath) {
        tl.to(maskPath, { strokeDashoffset: 0, ease: "none", duration: 5 }, 0);
    }

    tl.set(plane, { zIndex: 50 }, 2.5);

    if (textSpans.length > 0) {
        tl.to(textSpans, { opacity: 0, y: -50, duration: 1, ease: "power2.in", stagger: 0.02 }, 4.5);
    }
  };

  document.addEventListener("astro:page-load", initFlightDivider);
  
  if (document.readyState === "complete" || document.readyState === "interactive") {
    setTimeout(initFlightDivider, 10);
  } else {
    document.addEventListener("DOMContentLoaded", initFlightDivider);
  }
</script>

<style>
  .flight-divider-section {
    width: 100%;
    background-color: #ffffff;
  }

  .flight-divider-height {
    height: 80vh;
  }

  @media (--mq-tablet) {
    .flight-divider-height {
      height: 65vh;
    }
  }

  @media (--mq-phone) {
    .flight-divider-height {
      height: 50vh;
    }
    .flight-text span {
      font-size: 1.75rem !important;
    }
  }

  :global([data-theme="dark"]) .flight-divider-section {
    background-color: var(--color-bg);
  }
</style>
