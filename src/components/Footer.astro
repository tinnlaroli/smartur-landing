---
import logoImage from "../assets/imgs/logo_costado.png";
import type { Link } from "../types";

interface Props {
  logoUrl: string;
  logoAlt: string;
  links: Link[];
  slogan?: string;
  description?: string;
  quickLinksTitle?: string;
  contactTitle?: string;
  socialTitle?: string;
  copyright?: string;
  address?: string;
}

const {
  logoUrl,
  logoAlt,
  links,
  slogan,
  description,
  quickLinksTitle,
  contactTitle,
  socialTitle,
  copyright,
  address,
} = Astro.props;
---

<sy-footer>
  <footer>
    <div class="inner u-container">
      <div class="wrapper">
        <div class="footer-brand">
          <a class="logo" href={logoUrl}>
            <img
              src={logoImage.src}
              alt="Logotipo horizontal de SMARTUR - IA que guía, turismo que une"
              loading="lazy"
              decoding="async"
            />
            <span class="u-sr-only">{logoAlt}</span>
          </a>
          <p class="slogan">{slogan}</p>
          <p class="description">
            {description}
          </p>
        </div>

        <div class="footer-columns">
          <div class="footer-column">
            <h3 class="column-title">{quickLinksTitle}</h3>
            <ul>
              {
                links.map((l) => (
                  <li>
                    <a href={l.url}>{l.title}</a>
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="footer-column">
            <h3 class="column-title">{contactTitle}</h3>
            <ul class="contact-list">
              <li>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path
                    d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                  ></path>
                  <polyline points="22,6 12,13 2,6"></polyline>
                </svg>
                <a href="mailto:smarturutcv@gmail.com">smarturutcv@gmail.com</a>
              </li>
              <li>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path
                    d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                  ></path>
                </svg>
                <a href="tel:+522711730136">271 173 0136</a>
              </li>
              <li>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                  ></path>
                  <circle cx="12" cy="10" r="3"></circle>
                </svg>
                <span>{address}</span>
              </li>
            </ul>
          </div>

          <div class="footer-column">
            <h3 class="column-title">{socialTitle}</h3>
            <ul class="social-list">
              <li>
                <a
                  href="https://www.instagram.com/smar_tur?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw=="
                  target="_blank"
                  rel="noopener noreferrer"
                  class="social-link instagram"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5"
                    ></rect>
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                    ></path>
                    <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                  </svg>
                  <span>Instagram</span>
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>
      <p class="cp">© {new Date().getFullYear()} {logoAlt}. {copyright}</p>
    </div>
  </footer>
</sy-footer>

<style>
  sy-footer {
    @extend %u-text;

    --fs: var(--font-size-sm);
    display: block;
    clip-path: inset(0);

    :global(&.has-no-anim footer) {
      position: static;
    }
  }

  footer {
    background: rgba(var(--rgb-bg), 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    color: var(--color-text);
    position: fixed;
    bottom: 0;
    width: 100%;
    box-shadow: 0 -2px 8px rgba(var(--rgb-text), 0.08);
    border-top: 1px solid rgba(var(--rgb-text), 0.05);
  }

  .inner {
    padding: 2rem 0 1.25rem;

    @media (--mq-phone) {
      padding: 1.5rem 0 1rem;
    }
  }

  .wrapper {
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: 3rem;
    margin-bottom: 2rem;

    @media (--mq-tablet) {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .logo {
    position: relative;
    z-index: 3;

    img {
      height: 7rem;
      width: auto;
    }
  }

  .slogan {
    @extend %u-text;
    --fs: var(--font-size-md);
    --fw: 600;
    font-style: italic;
    color: var(--color-purple);
    margin: 0;
  }

  .description {
    @extend %u-text;
    --fs: var(--font-size-sm);
    color: var(--color-text-alt);
    line-height: 1.6;
    margin: 0;
    max-width: 32em;
  }

  .footer-columns {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;

    @media (--mq-tablet) {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  .footer-column {
    h3.column-title {
      @extend %u-text;
      --fs: var(--font-size-sm);
      --fw: 700;
      color: var(--color-text);
      margin-bottom: 1.25rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    ul {
      display: flex;
      flex-direction: column;
      padding: 0;
      gap: 1rem;
      margin: 0;
      list-style: none;

      li {
        @extend %u-text;
        --fs: var(--font-size-sm);
        color: var(--color-text-alt);
      }

      a {
        text-decoration: none;
        position: relative;
        transition: color 0.2s var(--ease-out-cubic);

        &:hover,
        &:focus {
          color: var(--color-purple);
        }
      }
    }
  }

  .contact-list {
    li {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;

      svg {
        flex-shrink: 0;
        margin-top: 0.15rem;
        color: var(--color-purple);
        opacity: 0.7;
      }

      a,
      span {
        flex: 1;
        line-height: 1.5;
      }
    }
  }

  .social-list {
    gap: 0.75rem !important;

    .social-link {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.75rem 1rem;
      border-radius: 0.5rem;
      background: rgba(var(--rgb-text), 0.03);
      border: 1px solid rgba(var(--rgb-text), 0.08);
      transition: all 0.3s var(--ease-out-cubic);

      svg {
        flex-shrink: 0;
        transition: transform 0.3s var(--ease-out-cubic);
      }

      span {
        font-weight: 600;
      }

      &:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(var(--rgb-text), 0.1);
      }

      &.instagram:hover {
        background: rgba(var(--rgb-pink-primary), 0.1);
        border-color: var(--color-pink);
        color: var(--color-pink);

        svg {
          transform: scale(1.1);
        }
      }

      &.facebook:hover {
        background: rgba(var(--rgb-cyan-accent), 0.1);
        border-color: var(--color-cyan);
        color: var(--color-cyan);

        svg {
          transform: scale(1.1);
        }
      }

      &.linkedin:hover {
        background: rgba(var(--rgb-purple-accent), 0.1);
        border-color: var(--color-purple);
        color: var(--color-purple);

        svg {
          transform: scale(1.1);
        }
      }
    }
  }

  .cp {
    @extend %u-text;
    --fs: var(--font-size-xs);
    text-align: center;
    color: var(--color-text-alt);
    opacity: 0.7;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(var(--rgb-text), 0.08);
    margin: 0;
  }
</style>

<script>
  import { addResizeObserver } from "../utils/observers";

  class Footer extends HTMLElement {
    connectedCallback() {
      addResizeObserver(this);

      this.onResize();
    }

    onResize() {
      const inner = this.firstElementChild as HTMLElement;
      const bcr = inner.getBoundingClientRect();

      if (bcr.height + 100 > window.innerHeight) {
        this.style.height = "";
        this.classList.add("has-no-anim");
      } else {
        this.style.height = `${bcr.height}px`;
        this.classList.remove("has-no-anim");
      }
    }
  }

  customElements.define("sy-footer", Footer);
</script>
