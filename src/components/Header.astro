---
import Button from "./Button.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import ThemeToggle from "./ThemeToggle.astro";
import logoImage from "../assets/imgs/logo.png";
import type { Link } from "../types";

interface Props {
  logoUrl: string;
  logoAlt: string;
  links: Link[];
  link1?: Link;
  link2?: Link;
  mobileMenuLabel?: string;
}

const { logoUrl, logoAlt, link1, link2, links, mobileMenuLabel = "Toggle Menu" } = Astro.props;
---

<header>
  <sy-head>
    <div class="inner u-container">
      <div class="wrapper">
        <a class="logo" href={logoUrl}>
          <img
            src={logoImage.src}
            alt="Logotipo de SMARTUR - Plataforma de Turismo Inteligente con IA"
            loading="eager"
            decoding="async"
          />
          <span class="u-sr-only">{logoAlt}</span>
        </a>

        <div class="menu">
          <ul>
            {
              links.map((l) => (
                <li>
                  <a href={l.url}>{l.title}</a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="buttons">
            {
            link1 ? (
              <Button 
                url={link1.url} 
                title={link1.title} 
                color="cyan" 
                size="md" 
                target="_blank" 
                revealable={false}
                external
              />
            ) : null
          }
          {link2 ? <Button {...link2} revealable={false} /> : null}
          
          <div class="controls">
            <LanguageSwitcher />
            <ThemeToggle />
          </div>

          <button type="button" class="toggle" aria-label={mobileMenuLabel}>
            <span class="u-sr-only">{mobileMenuLabel}</span>
            <span aria-hidden>
              <span></span>
              <span></span>
              <span></span>
            </span>
          </button>
        </div>
      </div>
    </div>
  </sy-head>
</header>

<style>
  sy-head {
    --br: 1.5rem;

    position: fixed;
    top: 0.75rem;
    left: 0;
    right: 0;
    z-index: 100;
    color: var(--color-text);
    margin: 0 auto;
    padding: 0.5rem 0;
    transition: transform 0.3s var(--ease-out-cubic);

    /* When menu is open, disable the transform to avoid stacking context issues */
    :global(body.is-nav-opened) & {
      transform: none !important;
    }

    /* ... existing styles ... */
    :global(body.is-nav-hidden) & {
      transform: translateY(calc(-100% - 0.75rem));
    }


    @media (--mq-tablet-sm) {
      --br: 1rem;
      top: 0.5rem;
    }

    &::before,
    &::after {
      content: "";
      width: 100%;
      height: 100%;
      position: absolute;
      top: 0;
      left: 0;
      z-index: -1;
    }

    &::after {
      background: rgba(var(--rgb-bg), 0.85);
      transition:
        transform 0.3s var(--ease-out-cubic),
        box-shadow 0.3s var(--ease-out-cubic);
      transform: scaleY(0);
      transform-origin: top;
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      box-shadow: 0 1px 3px rgba(var(--rgb-text), 0.05);
    }

    :global(body.is-nav-small) & {
      &::after {
        transform: scaleY(1);
        box-shadow: 0 2px 8px rgba(var(--rgb-text), 0.08);
      }
    }
  }

  .inner {
    padding: 0;
    transition: padding 0.3s var(--ease-out-cubic);

    :global(body.is-nav-small) & {
      padding: 0;
    }
  }

  .wrapper {
    position: relative;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    gap: 2.25rem;
    padding: 0.35rem 0;

    @media (--mq-tablet) {
      flex-wrap: wrap;
      gap: 1.5rem;
    }
  }

  .logo {
    position: relative;
    z-index: 3;
    flex-shrink: 0;

    img {
      height: 3.2rem;
      width: auto;
    }
  }

  .menu {
    display: flex;
    margin-left: 2rem;
    width: auto;
    
    /* Adjust menu item spacing */
    @media (max-width: 1024px) {
      :global(ul) {
        gap: 1.25em;
      }
    }

    @media (--mq-tablet) {
      align-items: center;
      justify-content: center;
      width: 100vw;
      height: 100vh;
      position: fixed;
      z-index: 2;
      background: rgba(var(--rgb-bg), 0.98);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      top: 0;
      left: 0;
      margin: 0;
      clip-path: inset(0 0 0%);
      transition: clip-path 0.5s var(--ease-out-expo);

      :global(body:not(.is-nav-opened)) & {
        clip-path: inset(0 0 100%);
        pointer-events: none;
      }

      :global(body.is-nav-small:not(.is-nav-opened)) & {
        clip-path: inset(
          0 0 calc(100% - 3.75rem) round 0 0 var(--br) var(--br)
        );
      }
    }

    @media (--mq-phone) {
      :global(body.is-nav-small:not(.is-nav-opened)) & {
        clip-path: inset(0 0 calc(100% - 3.375rem) round 0 0 1rem 1rem);
      }
    }

    :global(ul) {
      @extend %u-text;

      --fs: var(--font-size-base);
      display: flex;
      list-style: none;
      padding: 0;
      margin: 0;
      align-items: center;
      gap: 1.75em;

      @media (--mq-tablet) {
        flex-direction: column;
        font-size: 2rem;
        gap: 1rem;
        color: var(--color-text) !important; /* Force text color for visibility */
      }

      :global(li) {
        display: flex;
        align-items: center;
        gap: 1.3125em;

        @media (--mq-tablet) {
          flex-direction: column;
          gap: 1rem;
          opacity: 0;
          transform: translateY(20px);
          transition: opacity 0.4s ease, transform 0.4s ease;
        }

        &::after {
          display: inline-block;
          content: "";
          width: 2px;
          height: 2px;
        }

        &:last-child {
          &::after {
            display: none;
          }
        }
      }

      /* Staggered animation for menu items */
      @media (--mq-tablet) {
        :global(body.is-nav-opened) & :global(li) {
          opacity: 1;
          transform: translateY(0);
        }

        :global(body.is-nav-opened) & :global(li:nth-child(1)) { transition-delay: 0.1s; }
        :global(body.is-nav-opened) & :global(li:nth-child(2)) { transition-delay: 0.2s; }
        :global(body.is-nav-opened) & :global(li:nth-child(3)) { transition-delay: 0.3s; }
        :global(body.is-nav-opened) & :global(li:nth-child(4)) { transition-delay: 0.4s; }
        :global(body.is-nav-opened) & :global(li:nth-child(5)) { transition-delay: 0.5s; }
      }

      :global(a) {
        text-decoration: none;
        position: relative;
        color: var(--color-text) !important; /* Ensure links are visible */

        @media (--mq-tablet) {
          color: var(--color-text) !important;
          font-weight: 500;
        }

        &::before {
          content: "";
          position: absolute;
          height: 2px;
          background: currentcolor;
          top: 115%;
          width: 100%;
          left: 0;
          pointer-events: none;
          transform: scaleX(0);
          transition: transform 0.3s var(--ease-out-expo);
          transform-origin: right;
        }

        &:hover,
        &:focus {
          color: var(--color-purple) !important;

          &::before {
            transform: scaleX(1);
            transform-origin: left;
          }
        }
      }
    }
  }

  .buttons {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    z-index: 2;
    margin-left: auto;

    @media (--mq-tablet) {
      gap: 1.5rem;
      position: relative;
      z-index: 100;
    }

    @media (max-width: 1024px) {
      gap: 0.9rem;
    }
  }

  .controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-left: 1rem;
    margin-left: 1rem;
    border-left: 1px solid rgba(var(--rgb-text), 0.1);

    @media (max-width: 1024px) {
      padding-left: 0.75rem;
      margin-left: 0.75rem;
    }

    @media (--mq-tablet) {
      border-left: none;
      padding-left: 0;
      margin-left: 0;
    }
  }

  .signup {
    @media (--mq-phone) {
      display: none;
    }
  }



  .toggle {
    border: none;
    background: none;
    padding: 0.75rem;
    margin: -0.75rem;
    cursor: pointer;
    align-self: center;
    align-items: center;
    justify-content: center;
    display: none;
    position: relative;
    z-index: 110;
    color: var(--color-text);
    transition: color 0.3s var(--ease-out-expo);
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
    min-width: 44px;
    min-height: 44px;

    :global(.has-no-bg &) {
      color: var(--color-pink);
    }

    :global(body.is-nav-opened) &,
    :global(body.is-nav-small) & {
      color: var(--color-purple);
    }

    @media (--mq-tablet) {
      display: flex;
    }

    > span:last-child {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      height: 1.25rem;
      width: 1.75rem;

      span {
        display: block;
        width: 100%;
        height: 3px;
        background: currentColor;
        border-radius: 10px;
        transition: transform 0.2s var(--ease-out-cubic), opacity 0.2s;
        transform: translateZ(0);

        &:nth-child(2) {
          transition-property: opacity;
        }
      }
    }

    :global(body.is-nav-opened) & {
      color: var(--color-purple);

      > span {
        span {
          &:first-child {
            transform: translateY(calc(0.625rem - 1.5px)) rotate(45deg);
          }

          &:nth-child(2) {
            opacity: 0;
          }

          &:last-child {
            transform: translateY(calc(-0.625rem + 1.5px)) rotate(-45deg);
          }
        }
      }
    }
  }

  /* Active state for navigation links */
  .menu :global(a.is-active) {
    color: var(--color-purple) !important;
  }

  .menu :global(a.is-active::before) {
    transform: scaleX(1);
    transform-origin: left;
  }
</style>

<script>
  import { addScrollObserver } from "../utils/observers";

  const heroSelectors = ["sy-hero-home"];

  class Header extends HTMLElement {
    smallThreshold = 100;
    hiddenThreshold = 200;
    hero = document.querySelector(heroSelectors.join(","));
    prevY = -1;

    constructor() {
      super();
      addScrollObserver(this);
    }

    connectedCallback() {
      const toggleEl = this.querySelector(".toggle");
      if (toggleEl) {
        toggleEl.addEventListener("click", (e) => {
          e.preventDefault();
          e.stopPropagation();
          this.toggleNav();
        });
      }

      const menuLinks = this.querySelectorAll(".menu a[href^='#']");
      menuLinks.forEach((link) => {
        link.addEventListener("click", () => {
          document.body.classList.remove("is-nav-opened");
        });
      });

      this.onResize();
      this.onScroll(typeof window !== "undefined" ? window.scrollY : 0);
      
      this.initScrollSpy();
    }

    initScrollSpy() {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              // Find the link corresponding to this section
              const id = entry.target.id;
              const link = this.querySelector(`.menu a[href="#${id}"]`);
              if (link) {
                // Remove active class from all links
                this.querySelectorAll(".menu a").forEach((l) => l.classList.remove("is-active"));
                // Add active class to the current link
                link.classList.add("is-active");
              }
            }
          });
        },
        {
          rootMargin: "-20% 0px -60% 0px", // Trigger when section is near the top
          threshold: 0,
        }
      );

      // Select all sections that have a corresponding link in the menu
      const links = this.querySelectorAll(".menu a[href^='#']");
      links.forEach((link) => {
        const href = link.getAttribute("href");
        if (href && href.length > 1) {
          const id = href.substring(1);
          const section = document.getElementById(id);
          if (section) {
            observer.observe(section);
          }
        }
      });
    }

    onScroll(y: number) {
      const isDown = y > this.prevY ? true : false;
      this.prevY = y;

      const classList = document.body.classList;

      const shouldBeSmall = y > this.smallThreshold;
      const isSmall = classList.contains("is-nav-small");

      if (shouldBeSmall !== isSmall) {
        classList.toggle("is-nav-small", shouldBeSmall);
      }

      const shouldBeHidden = y > this.hiddenThreshold && isDown;
      const isHidden = classList.contains("is-nav-hidden");

      if (shouldBeHidden !== isHidden) {
        classList.toggle("is-nav-hidden", shouldBeHidden);
      }
    }

    toggleNav = () => {
      document.body.classList.toggle("is-nav-opened");
      if (document.body.classList.contains("is-nav-opened")) {
        document.body.style.overflow = "hidden";
      } else {
        document.body.style.overflow = "";
      }
    };

    onResize() {
      const hero = this.hero;
      const bcr = this.getBoundingClientRect();
      const heroBcr = hero && hero.getBoundingClientRect();

      this.smallThreshold = heroBcr ? heroBcr.height - bcr.height : bcr.height;
    }
  }

  customElements.define("sy-head", Header);
</script>
