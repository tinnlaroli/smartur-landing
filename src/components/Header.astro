---
import Button from "./Button.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import ThemeToggle from "./ThemeToggle.astro";
import logoImage from "../assets/imgs/logo_arriba.png";
import type { Link } from "../types";

interface Props {
  logoUrl: string;
  logoAlt: string;
  links: Link[];
  link1?: Link;
  link2?: Link;
}

const { logoUrl, logoAlt, link1, link2, links } = Astro.props;
---

<header>
  <sy-head>
    <div class="inner u-container">
      <div class="wrapper">
        <a class="logo" href={logoUrl}>
          <img
            src={logoImage.src}
            alt="Logotipo de SMARTUR - Plataforma de Turismo Inteligente con IA"
            loading="eager"
            decoding="async"
          />
          <span class="u-sr-only">{logoAlt}</span>
        </a>

        <div class="menu">
          <ul>
            {
              links.map((l) => (
                <li>
                  <a href={l.url}>{l.title}</a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="buttons">
          {
            link1 ? (
              <a class="tourist-link" href={link1.url} target="_blank" rel="noopener noreferrer">
                <span>{link1.title}</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                  <polyline points="15 3 21 3 21 9"></polyline>
                  <line x1="10" y1="14" x2="21" y2="3"></line>
                </svg>
              </a>
            ) : null
          }
          {link2 ? <Button {...link2} revealable={false} /> : null}
          
          <div class="controls">
            <LanguageSwitcher />
            <ThemeToggle />
          </div>

          <button type="button" class="toggle" aria-label="">
            <span class="u-sr-only">Toggle Mobile Menu</span>
            <span aria-hidden>
              <span></span>
              <span></span>
              <span></span>
            </span>
          </button>
        </div>
      </div>
    </div>
  </sy-head>
</header>

<style>
  sy-head {
    --br: 1.5rem;

    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    color: var(--color-text);
    margin: 0 auto;
    transition: transform 0.3s var(--ease-out-cubic);

    :global(body.is-nav-hidden) & {
      transform: translateY(-100%);
    }

    @media (--mq-tablet-sm) {
      --br: 1rem;
    }

    &::before,
    &::after {
      content: "";
      width: 100%;
      height: 100%;
      position: absolute;
      top: 0;
      left: 0;
      z-index: -1;
    }

    &::after {
      background: rgba(var(--rgb-bg), 0.85);
      transition:
        transform 0.3s var(--ease-out-cubic),
        box-shadow 0.3s var(--ease-out-cubic);
      transform: scaleY(0);
      transform-origin: top;
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      box-shadow: 0 1px 3px rgba(var(--rgb-text), 0.05);
    }

    :global(body.is-nav-small) & {
      &::after {
        transform: scaleY(1);
        box-shadow: 0 2px 8px rgba(var(--rgb-text), 0.08);
      }
    }
  }

  .inner {
    padding: 0;
    transition: padding 0.3s var(--ease-out-cubic);

    :global(body.is-nav-small) & {
      padding: 0;
    }
  }

  .wrapper {
    position: relative;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    gap: 2rem;

    @media (--mq-tablet) {
      flex-wrap: wrap;
      gap: 1.5rem;
    }
  }

  .logo {
    position: relative;
    z-index: 3;
    flex-shrink: 0;

    img {
      height: 2.2rem; /* Reduced from 2.4rem */
      width: auto;
    }
  }

  .menu {
    display: flex;
    margin-left: 2rem;
    width: auto;
    
    /* Adjust menu item spacing */
    @media (max-width: 1024px) {
      :global(ul) {
        gap: 1.25em;
      }
    }

    @media (--mq-tablet) {
      align-items: center;
      justify-content: center;
      width: 100vw;
      height: 100vh;
      position: fixed;
      z-index: 2;
      background: rgba(var(--rgb-bg), 0.98);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      top: 0;
      left: 0;
      margin: 0;
      clip-path: inset(0 0 0%);
      transition: clip-path 0.5s var(--ease-out-expo);

      :global(body:not(.is-nav-opened)) & {
        clip-path: inset(0 0 100%);
        pointer-events: none;
      }

      :global(body.is-nav-small:not(.is-nav-opened)) & {
        clip-path: inset(
          0 0 calc(100% - 3.75rem) round 0 0 var(--br) var(--br)
        );
      }
    }

    @media (--mq-phone) {
      :global(body.is-nav-small:not(.is-nav-opened)) & {
        clip-path: inset(0 0 calc(100% - 3.375rem) round 0 0 1rem 1rem);
      }
    }

    :global(ul) {
      @extend %u-text;

      --fs: var(--font-size-sm);
      display: flex;
      list-style: none;
      padding: 0;
      margin: 0;
      align-items: center;
      gap: 1.75em;

      @media (--mq-tablet) {
        color: var(--color-text);
      }

      @media (--mq-tablet) {
        flex-direction: column;
        font-size: 2rem;
        gap: 1rem;
      }

      :global(li) {
        display: flex;
        align-items: center;
        gap: 1.3125em;

        @media (--mq-tablet) {
          flex-direction: column;
          gap: 1rem;
        }

        &::after {
          display: inline-block;
          content: "";
          width: 2px;
          height: 2px;
        }

        &:last-child {
          &::after {
            display: none;
          }
        }
      }

      :global(a) {
        text-decoration: none;
        position: relative;

        &::before {
          content: "";
          position: absolute;
          height: 2px;
          background: currentcolor;
          top: 115%;
          width: 100%;
          left: 0;
          pointer-events: none;
          transform: scaleX(0);
          transition: transform 0.3s var(--ease-out-expo);
          transform-origin: right;
        }

        &:hover,
        &:focus {
          &::before {
            transform: scaleX(1);
            transform-origin: left;
          }
        }
      }
    }
  }

  .buttons {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    z-index: 2;
    margin-left: auto;

    /* Intermediate breakpoint for narrower screens */
    @media (max-width: 1024px) {
      gap: 0.9rem;
    }

    @media (--mq-tablet) {
      gap: 1.5rem;
    }
  }

  .controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-left: 1rem;
    margin-left: 1rem;
    border-left: 1px solid rgba(var(--rgb-text), 0.1);

    @media (max-width: 1024px) {
      padding-left: 0.75rem;
      margin-left: 0.75rem;
    }

    @media (--mq-tablet) {
      border-left: none;
      padding-left: 0;
      margin-left: 0;
    }
  }

  .signup {
    @media (--mq-phone) {
      display: none;
    }
  }

  .tourist-link {
    @extend %u-text;

    --fs: var(--font-size-xs);
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    background: rgba(var(--rgb-cyan-accent), 0.08);
    border: 1px solid rgba(var(--rgb-cyan-accent), 0.2);
    color: var(--color-cyan);
    font-weight: 600;
    white-space: nowrap;
    transition: all 0.3s var(--ease-out-cubic);
    flex-shrink: 0;

    svg {
      flex-shrink: 0;
      width: 14px;
      height: 14px;
      transition: transform 0.3s var(--ease-out-cubic);
    }

    &:hover,
    &:focus {
      background: rgba(var(--rgb-cyan-accent), 0.15);
      border-color: var(--color-cyan);
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(var(--rgb-cyan-accent), 0.2);

      svg {
        transform: translate(2px, -2px);
      }
    }

    /* Hide on narrower screens */
    @media (max-width: 1100px) {
      display: none;
    }

    @media (--mq-phone) {
      display: none;
    }
  }

  .toggle {
    border: none;
    background: none;
    padding: 0;
    cursor: pointer;
    align-self: normal;
    align-items: center;
    display: none;
    z-index: 2;
    color: var(--color-purple);
    transition: color 0.3s var(--ease-out-expo);

    :global(.has-no-bg &) {
      color: var(--color-pink);
    }

    :global(body.is-nav-opened &),
    :global(body.is-nav-small) & {
      color: var(--color-purple);
    }

    @media (--mq-tablet) {
      display: flex;
    }

    > span:last-child {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      height: 1.5rem;
      width: 2.25rem;

      span {
        display: flex;
        width: 100%;
        height: 4px;
        background: currentcolor;
        border-radius: 10px;
        transition: transform 0.2s var(--ease-out-cubic);
        transform: translateZ(0);

        &:nth-child(2) {
          transition-property: opacity;
        }
      }
    }

    :global(body.is-nav-opened) & {
      color: var(--color-purple);

      > span {
        span {
          &:first-child {
            transform: translateY(calc(0.75rem - 2px)) rotate(45deg);
          }

          &:nth-child(2) {
            opacity: 0;
          }

          &:last-child {
            transform: translateY(calc(-0.75rem + 2px)) rotate(-45deg);
          }
        }
      }
    }
  }
</style>

<script>
  import { addScrollObserver } from "../utils/observers";

  const heroSelectors = ["sy-hero-home"];

  class Header extends HTMLElement {
    smallThreshold = 100;
    hiddenThreshold = 200;
    toggleEl = this.querySelector(".toggle")!;
    hero = document.querySelector(heroSelectors.join(","));
    prevY = -1;

    constructor() {
      super();

      addScrollObserver(this);

      this.toggleEl.addEventListener("click", this.toggleNav);

      // addResizeObserver(this);

      this.onResize();
      this.onScroll(window.scrollY);
    }

    onScroll(y: number) {
      const isDown = y > this.prevY ? true : false;
      this.prevY = y;

      const classList = document.body.classList;

      const shouldBeSmall = y > this.smallThreshold;
      const isSmall = classList.contains("is-nav-small");

      if (shouldBeSmall !== isSmall) {
        classList.toggle("is-nav-small", shouldBeSmall);
      }

      const shouldBeHidden = y > this.hiddenThreshold && isDown;
      const isHidden = classList.contains("is-nav-hidden");

      if (shouldBeHidden !== isHidden) {
        classList.toggle("is-nav-hidden", shouldBeHidden);
      }
    }

    toggleNav = () => {
      document.body.classList.toggle("is-nav-opened");
    };

    onResize() {
      const hero = this.hero;
      const bcr = this.getBoundingClientRect();
      const heroBcr = hero && hero.getBoundingClientRect();

      this.smallThreshold = heroBcr ? heroBcr.height - bcr.height : bcr.height;
    }
  }

  customElements.define("sy-head", Header);
</script>
