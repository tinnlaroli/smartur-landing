---
import type { Link } from "../types";
import Button from "./Button.astro";


interface Props {
  title: string;
  subtitle?: string;
  cta?: Link;
}

const { title, subtitle, cta } = Astro.props;
---

<div class="sy-hero-home" id="hero-section">
  <!-- Background shimmer for post-load animation -->
  <div class="hero-shimmer"></div>

  <div class="u-container container">
    <div class="inner">
      <div class="content">
        <h1 class="u-heading title hero-title" set:html={title} />
        {
          subtitle ? (
            <p class="u-text subtitle hero-subtitle">{subtitle}</p>
          ) : null
        }
        {
          cta ? (
            <div class="cta-wrapper hero-cta">
              <Button
                {...cta}
                arrow
                class="cta"
                ariaLabel="Descubrir más sobre SMARTUR"
              />
              <div class="cta-shimmer" />
            </div>
          ) : null
        }
      </div>
      <div class="video-wrapper hero-video-wrap">
        <!-- 3D Phone Container -->
      </div>
    
    </div>
  </div>
</div>

<style>
  .sy-hero-home {
    position: relative;
    overflow: hidden;
    background: var(--color-bg);
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      120deg,
      transparent 0%,
      rgba(var(--rgb-purple-accent), 0.06) 30%,
      rgba(var(--rgb-pink-primary), 0.08) 50%,
      rgba(var(--rgb-cyan-accent), 0.06) 70%,
      transparent 100%
    );
    transform: translateX(-100%);
    z-index: 0;
    pointer-events: none;
    opacity: 0;
  }

  .container {
    position: relative;
    z-index: 1;
  }

  .inner {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 5rem;
    padding: 4rem 0;
    position: relative;

    @media (--mq-desktop-lg) {
      gap: 4rem;
      padding: 3rem 0;
    }

    @media (--mq-tablet) {
      flex-direction: column;
      align-items: flex-start;
      gap: 4rem;
      padding: 3rem 0 2rem;
    }

    @media (--mq-phone) {
      padding: 2.5rem 0 1rem;
      gap: 3rem;
    }
  }

  .content {
    flex: 1;
    max-width: 720px;
    z-index: 2;

    @media (--mq-tablet) {
      max-width: 100%;
    }
  }

  .title {
    --fs: 4.8rem;
    --lh: 1.1;
    --fw: 700;
    color: var(--color-text);

    @media (--mq-desktop-lg) {
      --fs: 4.2rem;
    }

    @media (--mq-tablet) {
      --fs: 3.8rem;
    }

    @media (--mq-phone) {
      --fs: 3rem;
    }
  }

  /* Hero elements initially hidden — animated by GSAP */
  .hero-title {
    opacity: 0;
    transform: translateY(40px);
  }

  .hero-subtitle {
    opacity: 0;
    transform: translateY(30px);
    filter: blur(8px);
  }

  .hero-cta {
    opacity: 0;
    transform: scale(0.7);
  }

  .hero-video-wrap {
    opacity: 0;
    transform: translateX(80px) scale(0.92);
  }

  /* Once hero is revealed (fallback or post-animation) */
  .sy-hero-home.hero-revealed .hero-title,
  .sy-hero-home.hero-revealed .hero-subtitle,
  .sy-hero-home.hero-revealed .hero-cta,
  .sy-hero-home.hero-revealed .hero-video-wrap {
    opacity: 1;
    transform: none;
    filter: none;
  }

  .subtitle {
    --fs: var(--font-size-lg);
    max-width: 32em;
    margin-top: 1.75rem;
    line-height: 1.65;
    color: var(--color-text-alt);

    @media (--mq-phone) {
      --fs: var(--font-size-md);
    }
  }

  .cta {
    margin-top: 2.75rem;
  }

  .cta-wrapper {
    position: relative;
    display: inline-block;
    overflow: hidden;
    margin-top: 2.75rem;
  }

  .cta-shimmer {
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.3),
      transparent
    );
    transform: skewX(-20deg);
    pointer-events: none;
    z-index: 5;
  }

  /* Seamless video integration */
  .video-wrapper {
    flex-shrink: 0;
    width: 50%;
    max-width: 850px;
    aspect-ratio: 1 / 1;
    position: relative;
    z-index: 0;

    -webkit-mask-image: radial-gradient(
      ellipse 92% 92% at center,
      rgba(0, 0, 0, 1) 40%,
      rgba(0, 0, 0, 0.95) 60%,
      rgba(0, 0, 0, 0.75) 75%,
      rgba(0, 0, 0, 0.3) 88%,
      rgba(0, 0, 0, 0) 100%
    );
    mask-image: radial-gradient(
      ellipse 92% 92% at center,
      rgba(0, 0, 0, 1) 40%,
      rgba(0, 0, 0, 0.95) 60%,
      rgba(0, 0, 0, 0.75) 75%,
      rgba(0, 0, 0, 0.3) 88%,
      rgba(0, 0, 0, 0) 100%
    );

    @media (--mq-desktop-lg) {
      width: 80%;
      max-width: 750px;
    }

    @media (--mq-tablet) {
      width: 100%;
      max-width: 600px;
      margin: 0 auto;
    }

    @media (--mq-phone) {
      max-width: 450px;
    }
  }

  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 0;
  }
</style>

<script>
  import gsap from "gsap";
  import { initPhoneScene } from "../assets/3d/phone";

  let heroAnimated = false;

  function animateHero() {
    if (heroAnimated) return;
    heroAnimated = true;

    const hero = document.getElementById("hero-section");
    if (!hero) return;

    // Remove hero-revealed class to ensure GSAP animations are not overridden by CSS
    hero.classList.remove("hero-revealed");

    const titleEl = hero.querySelector(".hero-title") as HTMLElement;
    const subtitleEl = hero.querySelector(".hero-subtitle") as HTMLElement;
    const ctaEl = hero.querySelector(".hero-cta") as HTMLElement;
    const phoneContainer = hero.querySelector(".hero-video-wrap") as HTMLElement;
    const shimmerEl = hero.querySelector(".hero-shimmer") as HTMLElement;
    const ctaShimmer = hero.querySelector(".cta-shimmer") as HTMLElement;

    // Explicitly set initial states to ensure they are hidden before animation starts
    const elementsToHide = [titleEl, subtitleEl, ctaEl, phoneContainer].filter(el => el !== null);
    gsap.set(elementsToHide, { opacity: 0 });
    
    if (titleEl) gsap.set(titleEl, { y: 40 });
    if (subtitleEl) gsap.set(subtitleEl, { y: 30, filter: "blur(8px)" });
    if (ctaEl) gsap.set(ctaEl, { scale: 0.7 });
    if (phoneContainer) gsap.set(phoneContainer, { x: 80, scale: 0.92 });

    const tl = gsap.timeline({
      defaults: { ease: "power3.out" },
      onComplete() {
        hero.classList.add("hero-revealed");
      },
    });

    // ——— Background shimmer wash ———
    if (shimmerEl) {
       tl.to(
        shimmerEl,
        {
          opacity: 1,
          x: "200%",
          duration: 1.5,
          ease: "power2.inOut",
        },
        0,
      );

      tl.to(
        shimmerEl,
        {
          opacity: 0,
          duration: 0.5,
        },
        1.2,
      );
    }

    // ——— Title: words cascade ———
    if (titleEl) {
      const html = titleEl.innerHTML;
      const tempDiv = document.createElement("div");
      tempDiv.innerHTML = html;

      function wrapWords(node: Node): void {
        if (node.nodeType === Node.TEXT_NODE) {
          const text = node.textContent || "";
          const words = text.split(/(\s+)/);
          const frag = document.createDocumentFragment();
          words.forEach((w) => {
            if (w.trim()) {
              const span = document.createElement("span");
              span.className = "hero-word";
              span.style.display = "inline-block";
              span.textContent = w;
              frag.appendChild(span);
            } else if (w) {
              frag.appendChild(document.createTextNode(w));
            }
          });
          node.parentNode?.replaceChild(frag, node);
        } else if (node.nodeType === Node.ELEMENT_NODE) {
          const el = node as HTMLElement;
          if (el.tagName === "SPAN" && el.style.color) {
            el.classList.add("hero-word");
            el.style.display = "inline-block";
            return;
          }
          if (el.tagName === "BR") return;
          Array.from(node.childNodes).forEach(wrapWords);
        }
      }

      Array.from(tempDiv.childNodes).forEach(wrapWords);
      titleEl.innerHTML = tempDiv.innerHTML;

      const words = titleEl.querySelectorAll(".hero-word");

      gsap.set(titleEl, { opacity: 1, y: 0 });
      gsap.set(words, { opacity: 0, y: 50, rotateX: 45 });

      tl.to(
        words,
        {
          opacity: 1,
          y: 0,
          rotateX: 0,
          duration: 0.8,
          stagger: 0.08,
          ease: "back.out(1.2)",
        },
        0.1,
      );
    }

    // ——— Subtitle: blur-to-clear ———
    if (subtitleEl) {
      tl.to(
        subtitleEl,
        {
          opacity: 1,
          y: 0,
          filter: "blur(0px)",
          duration: 1,
        },
        0.5,
      );
    }

    // ——— CTA: scale with elastic ———
    if (ctaEl) {
      tl.to(
        ctaEl,
        {
          opacity: 1,
          scale: 1,
          duration: 1,
          ease: "elastic.out(1, 0.5)",
        },
        0.7,
      );

      if (ctaShimmer) {
        tl.to(
          ctaShimmer,
          {
            left: "150%",
            duration: 0.8,
            ease: "power2.inOut",
          },
          1.2,
        );
      }
    }

    // ——— Video/Phone: slide from right with bounce ———
    // Container only — 3D canvas handles its own fade-in via phone.ts
    if (phoneContainer) {
      tl.to(
        phoneContainer,
        {
          opacity: 1,
          x: 0,
          scale: 1,
          duration: 1.2,
          ease: "back.out(1.5)",
        },
        0.3, 
      );
    }
  }

  // Listen for loader completion event
  window.addEventListener("smartur:loaded", animateHero, { once: true });

  // Fallback: if no loader (instant navigation), reveal after small delay
  if (!document.body.classList.contains("is-loading")) {
    setTimeout(animateHero, 100);
  }

  // ——— 3D Phone: Load SEPARATELY during page loader phase ———
  // This runs while the user watches the loader animation,
  // so WebGL context + scene download don't interfere with hero text animation
  (function preload3D() {
    const phoneContainer = document.querySelector(".hero-video-wrap") as HTMLElement;
    if (!phoneContainer) return;
    try {
      initPhoneScene(phoneContainer);
    } catch (e) {
      console.warn("Failed to initialize 3D Phone scene:", e);
    }
  })();
</script>
