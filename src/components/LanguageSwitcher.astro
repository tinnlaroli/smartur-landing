---
import { languages } from "../i18n/ui";

const currentLang = Astro.url.pathname.split("/")[1] || "es";
const validLang = currentLang in languages ? currentLang : "es";
---

<div class="language-switcher">
  <button type="button" class="lang-trigger" aria-label="Change language">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="12" cy="12" r="10"></circle>
      <line x1="2" y1="12" x2="22" y2="12"></line>
      <path
        d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
      ></path>
    </svg>
    <span class="current-lang">{validLang.toUpperCase()}</span>
    <svg
      class="chevron"
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </button>

  <div class="lang-dropdown">
    {
      Object.entries(languages).map(([code, name]) => (
        <a
          href={code === "es" ? "/" : `/${code}/`}
          class:list={["lang-option", { active: code === validLang }]}
          data-lang={code}
        >
          <span class="lang-code">{code.toUpperCase()}</span>
          <span class="lang-name">{name}</span>
        </a>
      ))
    }
  </div>
</div>

<style>
  .language-switcher {
    position: relative;
  }

  .lang-trigger {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.4rem 0.5rem;
    background: rgba(var(--rgb-text), 0.05);
    border: none;
    border-radius: 0.4rem;
    color: var(--color-text);
    cursor: pointer;
    transition: all 0.3s var(--ease-out-cubic);
    font-size: 0.7rem;
    font-weight: 600;

    &:hover {
      background: rgba(var(--rgb-text), 0.1);
    }

    svg:first-child {
      width: 30px;
      height: 30px;
    }

    .current-lang {
      font-size: 0.7rem;
      letter-spacing: 0.05em;
    }

    .chevron {
      width: 14px;
      height: 14px;
      transition: transform 0.3s var(--ease-out-cubic);
    }

    /* Reduce padding on narrower screens */
    @media (max-width: 1024px) {
      padding: 0.35rem 0.5rem;
      gap: 0.3rem;

      svg:first-child {
        width: 20px;
        height: 20px;
      }

      .chevron {
        width: 12px;
        height: 12px;
      }
    }

    @media (--mq-phone) {
      padding: 0.35rem 0.5rem;

      svg:first-child {
        width: 20px;
        height: 20px;
      }
    }
  }

  .lang-dropdown {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    background: var(--color-bg);
    border: 1px solid rgba(var(--rgb-text), 0.1);
    border-radius: 0.5rem;
    box-shadow: 0 4px 20px rgba(var(--rgb-text), 0.15);
    min-width: 180px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all 0.3s var(--ease-out-cubic);
    z-index: 100;
    overflow: hidden;

    @media (--mq-tablet) {
      position: fixed;
      top: auto;
      bottom: 5rem;
      right: 1rem;
      left: 1rem;
      min-width: auto;
    }
  }

  .language-switcher:hover .lang-dropdown,
  .language-switcher:focus-within .lang-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .language-switcher:hover .chevron,
  .language-switcher:focus-within .chevron {
    transform: rotate(180deg);
  }

  .lang-option {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    text-decoration: none;
    color: var(--color-text);
    transition: all 0.2s var(--ease-out-cubic);
    border-bottom: 1px solid rgba(var(--rgb-text), 0.05);

    &:last-child {
      border-bottom: none;
    }

    &:hover {
      background: rgba(var(--rgb-purple-accent), 0.08);
      color: var(--color-purple);
    }

    &.active {
      background: rgba(var(--rgb-purple-accent), 0.12);
      color: var(--color-purple);
      font-weight: 600;

      .lang-code {
        color: var(--color-purple);
      }
    }

    .lang-code {
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      color: var(--color-text-alt);
    }

    .lang-name {
      font-size: 0.875rem;
    }
  }
</style>

<script>
  // Store language preference
  document.querySelectorAll(".lang-option").forEach((link) => {
    link.addEventListener("click", (e) => {
      const lang = (e.currentTarget as HTMLElement).dataset.lang;
      if (lang) {
        localStorage.setItem("smartur-lang", lang);
      }
    });
  });

  // Apply stored language preference on load
  const storedLang = localStorage.getItem("smartur-lang");
  if (storedLang && storedLang !== "es") {
    const currentPath = window.location.pathname;
    const pathLang = currentPath.split("/")[1];

    if (pathLang !== storedLang && !currentPath.includes(`/${storedLang}/`)) {
      window.location.href = `/${storedLang}/`;
    }
  }

  // Close dropdown when clicking outside
  document.addEventListener("click", (e) => {
    const switcher = document.querySelector(".language-switcher");
    if (switcher && !switcher.contains(e.target as Node)) {
      // Dropdown will close automatically via CSS :hover
    }
  });
</script>
