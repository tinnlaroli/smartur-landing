---
import circuitIcon from "../assets/imgs/circuit.png";
import leafIcon from "../assets/imgs/leaf.png";
import mountainIcon from "../assets/imgs/mountain.png";
import personIcon from "../assets/imgs/person.png";
---

<div id="page-loader" class="page-loader" aria-hidden="true">
  <!-- Vortex container (esto es lo que "explota") -->
  <div class="vortex-container">
    <!-- Logo central (pequeño al inicio) -->

    <!-- Orbital rings (los iconos que se convierten en anillos borrosos) -->
    <div class="orbital-ring ring-circuit">
      <div class="ring-icon">
        <img src={circuitIcon.src} alt="" />
      </div>
    </div>

    <div class="orbital-ring ring-leaf">
      <div class="ring-icon">
        <img src={leafIcon.src} alt="" />
      </div>
    </div>

    <div class="orbital-ring ring-mountain">
      <div class="ring-icon">
        <img src={mountainIcon.src} alt="" />
      </div>
    </div>

    <div class="orbital-ring ring-person">
      <div class="ring-icon">
        <img src={personIcon.src} alt="" />
      </div>
    </div>
  </div>

  <!-- Explosion overlay (para el efecto de expansión de color) -->
  <div class="explosion-overlay"></div>

  <!-- Counter (minimalista) -->
  <div class="loader-counter">
    <span class="counter-text">0</span><span class="counter-percent">%</span>
  </div>

  <!-- Progress bar -->
  <div class="loader-progress">
    <div class="loader-progress-bar"></div>
  </div>
</div>

<style>
  .page-loader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    pointer-events: all;
    background: var(--color-bg);
  }

  /* Vortex container */
  .vortex-container {
    position: relative;
    width: 400px;
    height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Central logo */
  .central-logo {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 10;
    opacity: 0;
  }

  .central-logo img {
    width: 140px;
    height: auto;
    display: block;
  }

  .logo-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(var(--rgb-purple-accent), 0.6),
      rgba(var(--rgb-pink-primary), 0.4),
      transparent
    );
    filter: blur(30px);
    opacity: 0;
    z-index: -1;
  }

  /* Orbital rings */
  .orbital-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 140px;
    height: 140px;
    opacity: 0;
  }

  .ring-icon {
    position: absolute;
    width: 50px; /* Uniform measure */
    height: 50px;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    transform-origin: center calc(70px); /* Keeps rotation centered in orbit */
    
    /* Harmonizing visual style */
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-bg);
    border: 1px solid currentColor; /* Inherits specific color (purple, green, etc) */
    box-shadow: 0 0 15px rgba(0, 0, 0, 0.05); /* Soft uniform shadow, safe for rotation */
  }

  .ring-icon img {
    width: 55%; /* Reduced size to float nicely inside the bubble */
    height: 55%;
    object-fit: contain;
  }

  /* Colores específicos para cada anillo */
  .ring-circuit {
    color: rgb(var(--rgb-purple-accent));
  }

  .ring-leaf {
    color: rgb(var(--rgb-green-accent));
  }

  .ring-mountain {
    color: rgb(var(--rgb-orange-cta));
  }

  .ring-person {
    color: rgb(var(--rgb-pink-primary));
  }

  /* Explosion overlay */
  .explosion-overlay {
    position: fixed;
    inset: 0;
    z-index: 9998;
    background: radial-gradient(
      circle at center,
      rgb(var(--rgb-purple-accent)),
      rgb(var(--rgb-pink-primary)),
      rgb(var(--rgb-cyan-accent))
    );
    opacity: 0;
    transform: scale(0);
    pointer-events: none;
  }

  /* Counter */
  .loader-counter {
    position: fixed;
    bottom: 35%;
    left: 50%;
    transform: translateX(-50%);
    z-index: 9999;
    font-family: var(--font-family-heading);
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--color-text-alt);
    opacity: 0;
    display: flex;
    align-items: baseline;
  }

  .counter-text {
    font-variant-numeric: tabular-nums;
    min-width: 2.5ch;
    text-align: right;
  }

  .counter-percent {
    font-size: 0.8em;
    opacity: 0.6;
    margin-left: 2px;
  }

  /* Progress bar */
  .loader-progress {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: rgba(var(--rgb-text), 0.05);
    z-index: 9999;
    overflow: hidden;
  }

  .loader-progress-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(
      90deg,
      rgb(var(--rgb-purple-accent)),
      rgb(var(--rgb-pink-primary)),
      rgb(var(--rgb-cyan-accent))
    );
    background-size: 200% 100%;
    animation: progressShimmer 1.5s linear infinite;
  }

  @keyframes progressShimmer {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }

  /* Responsive */
  @media (--mq-phone) {
    .vortex-container {
      width: 300px;
      height: 300px;
    }

    .central-logo img {
      width: 50px;
    }

    .orbital-ring {
      width: 110px;
      height: 110px;
    }

    .ring-icon {
      width: 35px;
      height: 35px;
      transform-origin: center calc(55px);
    }

    .loader-counter {
      font-size: 1rem;
      bottom: 35%;
    }
  }
</style>

<script>
  import gsap from "gsap";

  const loader = document.getElementById("page-loader");

  if (loader) {
    const counterEl = loader.querySelector(".counter-text");
    const progressBar = loader.querySelector(
      ".loader-progress-bar",
    ) as HTMLElement | null;
    const vortexContainer = loader.querySelector(".vortex-container");
    const centralLogo = loader.querySelector(".central-logo");
    const logoGlow = loader.querySelector(".logo-glow");
    const orbitalRings = loader.querySelectorAll(".orbital-ring");
    const ringIcons = loader.querySelectorAll(".ring-icon");
    const explosionOverlay = loader.querySelector(".explosion-overlay");
    const counterWrap = loader.querySelector(".loader-counter");

    const counter = { val: 0 };
    const tl = gsap.timeline();

    // Phase 1: Fade In
    tl.to(centralLogo, { opacity: 1, duration: 0.5, ease: "power2.out" }, 0.1);
    tl.to(logoGlow, { opacity: 0.6, duration: 0.5, ease: "power2.out" }, 0.2);
    tl.to(counterWrap, { opacity: 1, duration: 0.4, ease: "power2.out" }, 0.3);
    tl.to(
      orbitalRings,
      { opacity: 1, duration: 0.4, stagger: 0.05, ease: "power2.out" },
      0.4,
    );

    tl.set(".ring-circuit .ring-icon", { rotation: 0 }, 0);
    tl.set(".ring-leaf .ring-icon", { rotation: 90 }, 0);
    tl.set(".ring-mountain .ring-icon", { rotation: 180 }, 0);
    tl.set(".ring-person .ring-icon", { rotation: 270 }, 0);

    const rotateLoop = gsap.to(ringIcons, {
      rotation: "+=360",
      duration: 2,
      repeat: -1,
      ease: "none",
    });

    const progressTween = gsap.to(counter, {
      val: 90,
      duration: 2.5,
      ease: "power1.inOut",
      onUpdate() {
        if (counterEl) counterEl.textContent = String(Math.round(counter.val));
        if (progressBar)
          progressBar.style.width = Math.round(counter.val) + "%";
      },
    });

    const finishLoading = () => {
      progressTween.kill();

      const exitTl = gsap.timeline();

      exitTl.to(counter, {
        val: 100,
        duration: 0.5,
        ease: "power2.out",
        onUpdate() {
          if (counterEl)
            counterEl.textContent = String(Math.round(counter.val));
          if (progressBar)
            progressBar.style.width = Math.round(counter.val) + "%";
        },
      });

      exitTl.to(rotateLoop, { timeScale: 5, duration: 0.5 }, 0);

      exitTl.to(
        ringIcons,
        {
          filter: "blur(20px)",
          scale: 1.5,
          duration: 0.6,
          ease: "power2.in",
        },
        0.5,
      );

      exitTl.to(
        explosionOverlay,
        {
          opacity: 1,
          scale: 2,
          duration: 0.6,
          ease: "power2.out",
        },
        0.6,
      );

      exitTl.to(
        [counterWrap, ".loader-progress", vortexContainer],
        {
          opacity: 0,
          duration: 0.4,
        },
        0.6,
      );

      exitTl.to(
        loader,
        {
          opacity: 0,
          duration: 0.8,
          ease: "power2.inOut",
        },
        1.0,
      );

      exitTl.call(
        () => {
          window.dispatchEvent(new CustomEvent("smartur:loaded"));
          document.body.classList.remove("is-loading");
          loader.style.display = "none";
          rotateLoop.kill();
        },
        [],
        1.8,
      );
    };

    if (document.readyState === "complete") {
      setTimeout(finishLoading, 1500);
    } else {
      window.addEventListener("load", () => {
        setTimeout(finishLoading, 1000);
      });
      setTimeout(finishLoading, 5000);
    }
  }
</script>
