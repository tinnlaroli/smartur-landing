---
import Button from "./Button.astro";
import type { Link } from "../types";
import laRegionVideo from "../assets/video/laRegion.mp4";

interface Props {
  id?: string;
  title: string;
  text: string;
  cta?: Link;
  tags?: string[];
  videoLabel?: string;
}

const {
  id,
  title,
  text,
  cta,
  tags = ["Cultura", "Naturaleza", "Tradiciones"],
  videoLabel = "Video explorando la riqueza de Las Altas Montañas de Veracruz",
} = Astro.props;
---

<sy-region class="region" id={id || "region"}>
  <!-- Floating Tech Accents -->
  <div class="floating-accents" aria-hidden="true">
    <div class="accent accent--dot accent--1"></div>
    <div class="accent accent--dot accent--2"></div>
    <div class="accent accent--dot accent--3"></div>
    <div class="accent accent--ring accent--4"></div>
    <div class="accent accent--ring accent--5"></div>
    <div class="accent accent--line accent--6"></div>
    <div class="accent accent--line accent--7"></div>
    <div class="accent accent--node accent--8">
      <span></span><span></span><span></span>
    </div>
  </div>

  <div class="u-container region__grid">
    <!-- LEFT: Content Column (40%) -->
    <div class="region__content" data-sy-reveal="">
      <div class="content-glass">
        <div class="region__label">
          <span class="label-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </span>
          <span class="label-text">SMARTUR Region</span>
        </div>

        <h2 class="region__title sy-kinetic-heading" data-sy-reveal="" set:html={title} />

        <p class="region__description" data-sy-reveal="lines" set:html={text} />

        <!-- Keyword Tags — Subtle outline style -->
        <div class="region__tags" data-sy-reveal="">
          <div class="tag">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 21h18"></path>
              <path d="M9 8h1"></path><path d="M9 12h1"></path><path d="M9 16h1"></path>
              <path d="M14 8h1"></path><path d="M14 12h1"></path><path d="M14 16h1"></path>
              <path d="M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16"></path>
            </svg>
            <span>{tags[0]}</span>
          </div>
          <div class="tag">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22c4.97 0 9-2.69 9-6v-3c0-3.31-4.03-6-9-6s-9 2.69-9 6v3c0 3.31 4.03 6 9 6z"></path>
              <path d="M12 13c4.97 0 9-2.69 9-6s-4.03-6-9-6-9 2.69-9 6 4.03 6 9 6z"></path>
            </svg>
            <span>{tags[1]}</span>
          </div>
          <div class="tag">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
              <path d="M2 17l10 5 10-5"></path>
              <path d="M2 12l10 5 10-5"></path>
            </svg>
            <span>{tags[2]}</span>
          </div>
        </div>

        {cta && (
          <div class="region__cta" data-sy-reveal="">
            <Button {...cta} arrow class="cta-btn" />
          </div>
        )}
      </div>
    </div>

    <!-- RIGHT: Video Column (60%) -->
    <div class="region__video" data-sy-reveal="">
      <div class="video-frame">
        <video
          class="region-video"
          data-src={laRegionVideo}
          preload="metadata"
          playsinline
          muted
          loop
          aria-label={videoLabel}
        >
          Tu navegador no soporta el elemento de video.
        </video>

        <!-- Custom Play Button -->
        <button class="play-overlay" aria-label="Play video">
          <div class="play-ring">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </div>
        </button>

        <!-- Video duration badge -->
        <div class="video-badge">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="23 7 16 12 23 17 23 7"></polygon>
            <rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect>
          </svg>
          <span>Las Altas Montañas</span>
        </div>
      </div>
    </div>
  </div>
</sy-region>

<script>
  class SyRegion extends HTMLElement {
    connectedCallback() {
      const video = this.querySelector('.region-video') as HTMLVideoElement;
      const playBtn = this.querySelector('.play-overlay') as HTMLElement;

      if (!video || !playBtn) return;

      // Lazy load video
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const src = video.dataset.src;
            if (src && !video.src) {
              video.src = src;
              video.load();
            }
            observer.unobserve(video);
          }
        });
      }, { rootMargin: '300px', threshold: 0 });

      observer.observe(video);

      // Play/pause toggle
      playBtn.addEventListener('click', () => {
        if (video.paused) {
          video.play();
          playBtn.classList.add('is-playing');
        } else {
          video.pause();
          playBtn.classList.remove('is-playing');
        }
      });

      // Show play button when video ends or pauses
      video.addEventListener('pause', () => playBtn.classList.remove('is-playing'));
      video.addEventListener('play', () => playBtn.classList.add('is-playing'));
    }
  }

  customElements.define('sy-region', SyRegion);
</script>

<style>
  .region {
    display: block;
    position: relative;
    padding: 7rem 0;
    overflow: hidden;
    background: linear-gradient(
      165deg,
      rgba(var(--rgb-bg), 1) 0%,
      rgba(var(--rgb-cyan-accent), 0.04) 30%,
      rgba(var(--rgb-purple-accent), 0.06) 70%,
      rgba(var(--rgb-bg), 1) 100%
    );

    @media (--mq-tablet) {
      padding: 5rem 0;
    }

    @media (--mq-phone) {
      padding: 3.5rem 0;
    }
  }

  /* ── Floating Tech Accents ── */
  .floating-accents {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .accent {
    position: absolute;
  }

  .accent--dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(var(--rgb-purple-accent), 0.25);
    animation: float-dot 8s ease-in-out infinite;
  }

  .accent--1 { top: 15%; left: 8%; animation-delay: 0s; }
  .accent--2 { top: 60%; right: 12%; animation-delay: -2s; background: rgba(var(--rgb-cyan-accent), 0.25); }
  .accent--3 { bottom: 20%; left: 25%; animation-delay: -4s; background: rgba(var(--rgb-green-accent), 0.2); }

  .accent--ring {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 1.5px solid rgba(var(--rgb-purple-accent), 0.15);
    animation: float-ring 10s ease-in-out infinite;
  }

  .accent--4 { top: 25%; right: 5%; animation-delay: -1s; }
  .accent--5 { bottom: 30%; left: 4%; animation-delay: -5s; border-color: rgba(var(--rgb-cyan-accent), 0.15); }

  .accent--line {
    width: 35px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(var(--rgb-purple-accent), 0.15), transparent);
    animation: float-line 12s ease-in-out infinite;
  }

  .accent--6 { top: 20%; right: 25%; transform: rotate(30deg); animation-delay: -3s; }
  .accent--7 { bottom: 25%; left: 18%; transform: rotate(-15deg); animation-delay: -7s; background: linear-gradient(90deg, transparent, rgba(var(--rgb-cyan-accent), 0.15), transparent); }

  .accent--node {
    width: 40px;
    height: 40px;
    animation: float-node 14s ease-in-out infinite;
  }

  .accent--node span {
    position: absolute;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(var(--rgb-purple-accent), 0.2);
  }

  .accent--node span:nth-child(1) { top: 0; left: 50%; }
  .accent--node span:nth-child(2) { bottom: 10%; left: 10%; }
  .accent--node span:nth-child(3) { bottom: 10%; right: 10%; }

  .accent--node::before,
  .accent--node::after {
    content: "";
    position: absolute;
    background: rgba(var(--rgb-purple-accent), 0.1);
    height: 1px;
  }

  .accent--node::before {
    width: 18px;
    top: 3px;
    left: 5px;
    transform: rotate(55deg);
    transform-origin: left top;
  }

  .accent--node::after {
    width: 18px;
    top: 3px;
    right: 5px;
    transform: rotate(-55deg);
    transform-origin: right top;
  }

  .accent--8 { top: 12%; left: 45%; animation-delay: -2s; }

  @keyframes float-dot {
    0%, 100% { transform: translate(0, 0); opacity: 0.4; }
    50% { transform: translate(6px, -10px); opacity: 1; }
  }

  @keyframes float-ring {
    0%, 100% { transform: translate(0, 0) rotate(0deg); opacity: 0.3; }
    50% { transform: translate(-5px, 8px) rotate(90deg); opacity: 0.7; }
  }

  @keyframes float-line {
    0%, 100% { opacity: 0.2; transform: translateX(0) rotate(30deg); }
    50% { opacity: 0.6; transform: translateX(8px) rotate(35deg); }
  }

  @keyframes float-node {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.4; }
    50% { transform: translate(4px, -6px) scale(1.1); opacity: 0.8; }
  }

  /* ── Grid Layout — 40/60 Split ── */
  .region__grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 4rem;
    align-items: center;

    @media (--mq-desktop-sm) {
      gap: 3rem;
    }

    @media (--mq-tablet) {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  /* ── Content Column ── */
  .region__content {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.7s var(--ease-standard),
      transform 0.7s var(--ease-standard);

    &.is-in {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .content-glass {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 2rem;
    border-radius: 1.25rem;
    background: rgba(var(--rgb-bg), 0.5);
    backdrop-filter: blur(20px) saturate(1.2);
    -webkit-backdrop-filter: blur(20px) saturate(1.2);
    border: 1px solid rgba(var(--rgb-text), 0.05);

    @media (--mq-tablet) {
      padding: 1.5rem;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }

    @media (--mq-phone) {
      padding: 1.25rem;
    }
  }

  .region__label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .label-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 6px;
    background: rgba(var(--rgb-purple-accent), 0.1);
    color: var(--color-purple);
  }

  .label-text {
    font-family: var(--font-family-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-purple);
  }

  .region__title {
    font-family: var(--font-family-heading);
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0;
    background: linear-gradient(
      135deg,
      rgb(var(--rgb-purple-accent)) 0%,
      rgba(var(--rgb-cyan-accent), 0.9) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;

    @media (--mq-phone) {
      font-size: 1.75rem;
    }
  }

  .region__description {
    font-family: var(--font-family-body);
    font-size: 0.9375rem;
    font-weight: 400;
    line-height: 1.8;
    color: var(--color-text);
    margin: 0;
    max-width: 40ch;

    @media (--mq-phone) {
      font-size: 0.875rem;
      line-height: 1.7;
    }
  }

  /* ── Keyword Tags — Subtle Outline ── */
  .region__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.25rem;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.6s var(--ease-standard) 0.15s,
      transform 0.6s var(--ease-standard) 0.15s;

    &.is-in {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .tag {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    border-radius: 2rem;
    background: transparent;
    border: 1px solid rgba(var(--rgb-text), 0.12);
    color: var(--color-text-alt);
    font-family: var(--font-family-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: all 0.3s ease;

    svg {
      flex-shrink: 0;
      opacity: 0.6;
    }

    &:hover {
      background: rgba(var(--rgb-purple-accent), 0.06);
      border-color: rgba(var(--rgb-purple-accent), 0.25);
      color: var(--color-purple);
      transform: translateY(-1px);
    }

    &:nth-child(2):hover {
      background: rgba(var(--rgb-cyan-accent), 0.06);
      border-color: rgba(var(--rgb-cyan-accent), 0.25);
      color: var(--color-cyan);
    }

    &:nth-child(3):hover {
      background: rgba(var(--rgb-green-accent), 0.06);
      border-color: rgba(var(--rgb-green-accent), 0.25);
      color: var(--color-green);
    }
  }

  .region__cta {
    margin-top: 0.25rem;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.6s var(--ease-standard) 0.25s,
      transform 0.6s var(--ease-standard) 0.25s;

    &.is-in {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Video Column ── */
  .region__video {
    position: relative;
    opacity: 0;
    transform: translateY(25px) scale(0.97);
    transition:
      opacity 0.8s var(--ease-standard) 0.1s,
      transform 0.8s var(--ease-standard) 0.1s;

    &.is-in {
      opacity: 1;
      transform: translateY(0) scale(1);
    }

    @media (--mq-tablet) {
      order: -1;
    }
  }

  .video-frame {
    position: relative;
    width: 100%;
    border-radius: 1.25rem;
    overflow: hidden;
    box-shadow:
      0 16px 48px rgba(var(--rgb-purple-accent), 0.1),
      0 6px 20px rgba(var(--rgb-text), 0.06);
    border: 1px solid rgba(var(--rgb-text), 0.06);
    background: var(--color-bg-alt);
    transition: transform 0.4s var(--ease-out-cubic), box-shadow 0.4s ease;

    &:hover {
      transform: translateY(-4px);
      box-shadow:
        0 24px 64px rgba(var(--rgb-purple-accent), 0.15),
        0 10px 28px rgba(var(--rgb-text), 0.08);
    }
  }

  .region-video {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    background: var(--color-bg-alt);
  }

  /* ── Custom Play Button ── */
  .play-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: none;
    background: rgba(var(--rgb-bg), 0.15);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    transition: all 0.4s ease;
    z-index: 2;

    &:hover {
      background: rgba(var(--rgb-bg), 0.1);

      .play-ring {
        transform: scale(1.12);
        box-shadow: 0 8px 32px rgba(var(--rgb-orange-cta), 0.4);
      }
    }

    /* When playing, hide the overlay */
    &.is-playing {
      opacity: 0;
      pointer-events: none;
    }
  }

  .play-ring {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgb(var(--rgb-orange-cta)), rgb(var(--rgb-pink-primary)));
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    box-shadow: 0 6px 24px rgba(var(--rgb-orange-cta), 0.3);
    transition: all 0.3s var(--ease-out-cubic);

    svg {
      margin-left: 3px; /* Optical center adjustment */
    }

    @media (--mq-phone) {
      width: 52px;
      height: 52px;

      svg {
        width: 22px;
        height: 22px;
      }
    }
  }

  /* ── Video Badge ── */
  .video-badge {
    position: absolute;
    top: 0.875rem;
    left: 0.875rem;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    border-radius: 2rem;
    background: rgba(var(--rgb-bg), 0.65);
    backdrop-filter: blur(12px) saturate(1.3);
    -webkit-backdrop-filter: blur(12px) saturate(1.3);
    border: 1px solid rgba(var(--rgb-text), 0.08);
    color: var(--color-text);
    font-family: var(--font-family-body);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    z-index: 3;

    svg {
      color: var(--color-purple);
      flex-shrink: 0;
    }

    @media (--mq-phone) {
      top: 0.625rem;
      left: 0.625rem;
      font-size: 0.625rem;
      padding: 0.25rem 0.625rem;
    }
  }

  /* ── Responsive Hide ── */
  @media (--mq-tablet) {
    .floating-accents .accent--4,
    .floating-accents .accent--8 {
      display: none;
    }
  }
</style>
