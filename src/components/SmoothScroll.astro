<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { ScrollSmoother } from "gsap/ScrollSmoother";
  import { MotionPathPlugin } from "gsap/MotionPathPlugin";

  gsap.registerPlugin(ScrollTrigger, ScrollSmoother, MotionPathPlugin);

  const useNativeScroll = () =>
    window.matchMedia("(max-width: 987px)").matches || "ontouchstart" in window;

  function setupAnchorLinks(useSmoother: boolean, smoother?: { scrollTo: (href: string, a: boolean, b: string) => void }) {
    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener("click", (e) => {
        const href = (e.currentTarget as HTMLAnchorElement).getAttribute("href");
        if (!href || href === "#") return;
        e.preventDefault();
        const id = href.slice(1);
        const el = document.getElementById(id);
        if (el) {
          if (useSmoother && smoother) {
            smoother.scrollTo(href, true, "top top");
          } else {
            el.scrollIntoView({ behavior: "smooth", block: "start" });
          }
        }
      });
    });
  }

  const initSmoothScroll = () => {
    const wrapper = document.getElementById("smooth-wrapper");
    const content = document.getElementById("smooth-content");
    if (!wrapper || !content) return;

    if (useNativeScroll()) {
      document.body.classList.add("native-scroll");
      setupAnchorLinks(false);
      return;
    }

    document.body.classList.remove("native-scroll");
    const smoother = ScrollSmoother.create({
      wrapper: "#smooth-wrapper",
      content: "#smooth-content",
      smooth: 2,
      effects: true,
      smoothTouch: 0.1,
    });
    setupAnchorLinks(true, smoother);
  };

  document.addEventListener("astro:page-load", initSmoothScroll);
  if (document.readyState === "complete" || document.readyState === "interactive") {
    setTimeout(initSmoothScroll, 10);
  } else {
    document.addEventListener("DOMContentLoaded", initSmoothScroll);
  }
</script>

<style is:global>
  /* Optional: Hide scrollbar if needed, though ScrollSmoother handles it usually. 
     Astro's ViewTransitions might re-inject styles, so global styles here are safer. 
  */
</style>
