---
interface Props {
  title: string;
  items: {
    title: string;
    text: string;
  }[];
}

const { title, items } = Astro.props;
---

<sy-steps-timeline>
  <div class="u-container container">
    <div class="wrapper">
      <div class="content">
        <h2 class="u-heading title sy-kinetic-heading" data-sy-reveal="" set:html={title} />
      </div>
      <div class="items-wrapper">
        <div class="items">
          {
            items.map((item, i) => (
              <div class:list={["item", i === 0 && "is-active"]}>
                <div class="item-inner">
                  <h3 class="u-heading item-title" data-sy-reveal="words" set:html={item.title} />
                  <p class="u-text item-text" data-sy-reveal="lines">
                    {item.text}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
      
      <div class="logo-container">
        <img src="/src/assets/imgs/logo.png" alt="Smartur Logo" class="jumping-logo" />
      </div>
    </div>
    <div data-gl-place="0" data-gl-place-factor="1.05"></div>
    <div data-gl-place="1" data-gl-place-factor="1.01"></div>
  </div>
</sy-steps-timeline>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  class StepsTimeline extends HTMLElement {
    connectedCallback() {
      const itemsWrapper = this.querySelector(".items-wrapper");
      const wrapper = this.querySelector(".wrapper");
      const items = Array.from(this.querySelectorAll<HTMLElement>(".item"));
      
      if (!itemsWrapper || !wrapper || items.length === 0) return;

      const isMobile = window.matchMedia("(max-width: 767px)").matches;
      let current = 0;

      if (isMobile) {
        // No pin on mobile: use IntersectionObserver to set active step for fluidity
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              const idx = items.indexOf(entry.target as HTMLElement);
              if (idx < 0) return;
              items[current].classList.remove("is-active");
              items[idx].classList.add("is-active");
              current = idx;
            });
          },
          { rootMargin: "-30% 0px -30% 0px", threshold: 0 }
        );
        items.forEach((el) => observer.observe(el));
        return;
      }

      new ScrollTrigger({
        trigger: itemsWrapper,
        pin: wrapper,
        start: "center center",
        end: () => `+=${window.innerHeight * 2}px`,
        invalidateOnRefresh: true,
        onUpdate: (st) => {
          const index = Math.round(st.progress * (items.length - 1));
          if (index !== current) {
            items[current].classList.remove("is-active");
            items[index].classList.add("is-active");
            current = index;
          }
        },
      });
    }
  }

  customElements.define("sy-steps-timeline", StepsTimeline);
</script>

<style>
  [data-gl-place] {
    --d: 1;
    --s: 18rem;
    position: absolute;
  }

  [data-gl-place="0"] {
    right: 10%;
    top: 0;
    bottom: 0;

    @media (--mq-tablet) {
      top: -20vh;
    }
  }

  [data-gl-place="1"] {
    top: 200vh;
    right: 10%;

    @media (--mq-tablet) {
      top: 100vh;
    }
  }

  /* Logo Animation Styles */
  .logo-container {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    pointer-events: none;
    
    @media (--mq-laptop) {
      right: -5%;
      transform: translateY(-50%) scale(0.8);
    }

    @media (--mq-tablet) {
      display: none; 
    }
  }

  .jumping-logo {
    width: 28rem; /* Increased size */
    height: auto;
    filter: drop-shadow(0 10px 20px rgba(0,0,0,0.15));
    animation: jump 3s infinite ease-in-out;
  }

  @keyframes jump {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-30px);
    }
  }

  sy-steps-timeline {
    display: block;
    position: relative;
    padding: 7rem 0; /* Changed from margin to padding to match About */
    margin: 0;
    z-index: 9;
    background: var(--color-bg); /* Ensure defined background */
  }

  .container {
    position: relative;
    z-index: 2;
  }

  .content {
    position: relative;
    width: 100%;
    margin: 0;
    padding: 0;

    @media (--mq-tablet) {
      display: contents;
    }
  }

  .title {
    --fs: 3rem;
    --lh: 1;
    max-width: 10em;
    margin-bottom: 1em;
    padding: 0; /* Ensure no padding shift */
  }

  .wrapper {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-start;
    position: relative;
    width: 100%;
    margin: 0;
    padding: 0; /* Strict zero padding */
  }

  .items-wrapper {
    display: flex;
    padding-left: 4rem;
    position: relative;
    backdrop-filter: blur(6px) saturate(1.05);

    @media (--mq-desktop-sm) {
      max-width: 34rem;
    }

    @media (--mq-desktop-xs) {
      max-width: 30rem;
    }

    @media (--mq-tablet-sm) {
      max-width: 36rem;
      align-self: center;
      padding-left: 0;
    }

    &::before {
      content: "";
      display: block;
      min-height: 100%;
      min-width: 8px; /* Thicker bar */
      margin-right: 3rem;
      background: var(--color-purple); 
      border-radius: 4px;

      @media (--mq-tablet-sm) {
        margin-right: 1.5rem;
      }
    }
  }

  .items {
    display: flex;
    flex-direction: column;
    max-width: 33rem;
    width: 100%;
    counter-reset: items;
    max-width: 24rem;
  }

  .item-inner {
    display: flex;
    position: relative;
    flex-direction: column;
    gap: 0.5rem;
    padding: 2rem 1rem;

    &::before {
      @extend %u-text;
      --fs: 1.2rem;
      --fw: 500;
      display: flex;
      align-items: center;
      counter-increment: items;
      content: counter(items, decimal-leading-zero);
      position: absolute;
      right: calc(100% + 3rem + 4rem);
      transform: translateX(100%);
      text-align: center;
      top: 0;
      bottom: 0;
      margin: auto;
      transition: all 0.6s var(--ease-out-cubic);
      border-right: 8px solid transparent;
      padding-right: calc(4rem - 8px);
      width: 0;
      opacity: 0.3;
      border-radius: 4px;
      color: var(--color-text-alt);

      @media (--mq-tablet-sm) {
        right: calc(100% + 1.5rem + 4rem);
      }
    }

      :global(.item.is-active &) {
        &::before {
          opacity: 1;
          border-right-color: var(--color-orange);
          color: var(--color-text);
          padding-right: calc(4rem - 8px); /* Ensure padding stays consistent or animates if needed */
        }
      }
  }

  /* Add transition to the item content itself for better focus */
  .item {
    transition: opacity 0.6s var(--ease-out-cubic);
    opacity: 0.3;
  }
  
  .item.is-active {
    opacity: 1;
  }

  .item-title {
    --fs: 1.2rem;
    --fw: 500;
  }

  .item-text {
    --fs: var(--font-size-xs);
  }
</style>
