---
import { ui } from "../i18n/ui";
import circuitImg from "../assets/imgs/circuit.png";
import {
  Target,
  TrendingUp,
  Store,
  ShieldCheck,
  ArrowRight,
} from "lucide-react";
import Button from "./Button.astro";

// Stat Interface
interface Stat {
  number: string;
  suffix: string;
  label: string;
}

interface Props {
  lang?: keyof typeof ui;
  id?: string;
  stats?: Stat[];
}

const { lang = "es", id, stats } = Astro.props;
const t = ui[lang];

// Content Data - Partner Benefits
const BENEFITS = [
  {
    title: t["tech.partner.feature1.title"],
    desc: t["tech.partner.feature1.desc"],
    Icon: Target,
    colorClass: "feature-purple",
    bgClass: "feature-bg-purple",
    gradient: "via-purple-500",
  },
  {
    title: t["tech.partner.feature2.title"],
    desc: t["tech.partner.feature2.desc"],
    Icon: TrendingUp,
    colorClass: "feature-blue",
    bgClass: "feature-bg-blue",
    gradient: "via-blue-500",
  },
  {
    title: t["tech.partner.feature3.title"],
    desc: t["tech.partner.feature3.desc"],
    Icon: Store,
    colorClass: "feature-cyan",
    bgClass: "feature-bg-cyan",
    gradient: "via-cyan-500",
  },
  {
    title: t["tech.partner.feature4.title"],
    desc: t["tech.partner.feature4.desc"],
    Icon: ShieldCheck,
    colorClass: "feature-green",
    bgClass: "feature-bg-green",
    gradient: "via-green-500",
  },
];
---

<section
  class="tech-section relative py-16 sm:py-20 md:py-24 overflow-hidden transition-colors duration-500"
  id={id}
>
  {/* Dynamic Background Pattern */}
  <div
    class="circuit-pattern absolute inset-0 pointer-events-none opacity-[0.03]"
    style={`background-image: url(${circuitImg.src}); background-size: 500px;`}
  >
  </div>

  {/* Aesthetic Glow - CSS Controlled visibility */}
  <div
    class="tech-glow absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-3xl h-[600px] blur-[100px] rounded-full pointer-events-none"
  >
  </div>

  <div class="container mx-auto px-4 relative z-10">
    {/* Header */}
    <div class="text-center max-w-3xl mx-auto mb-12 md:mb-16 lg:mb-20">
      <h2
        class="section-title reveal-fade-up text-4xl md:text-5xl font-extrabold mb-6 leading-tight"
        style="animation-delay: 100ms;"
        set:html={t["tech.partner.title"]}
      />

      <p
        class="section-desc reveal-fade-up text-lg md:text-xl leading-relaxed max-w-2xl mx-auto"
        style="animation-delay: 200ms;"
      >
        {t["tech.partner.intro"]}
      </p>
    </div>

    {/* Feature Grid */}
    <div
      class="grid tech-grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-16"
    >
      {
        BENEFITS.map((feature, index) => (
          <div
            class="feature-card group reveal-fade-up relative p-8 rounded-3xl border 
                 hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 ease-out overflow-hidden flex flex-col items-center text-center md:items-start md:text-left"
            style={`animation-delay: ${300 + index * 100}ms`}
          >
            {/* Subtle Gradient Overlay on Hover */}
            <div
              class={`absolute inset-0 bg-gradient-to-br from-white/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none overlay-gradient`}
            />

            {/* Icon Box */}
            <div
              class={`relative w-16 h-16 rounded-2xl flex items-center justify-center mb-6 text-3xl shadow-sm ${feature.bgClass} ${feature.colorClass} 
                       group-hover:scale-110 group-hover:rotate-3 transition-transform duration-500 ease-spring`}
            >
              <feature.Icon size={32} strokeWidth={1.5} />
            </div>

            <h3
              class={`card-title relative text-xl font-bold mb-3 transition-colors duration-300 group-hover:${feature.colorClass.replace("feature-", "text-")}-600`}
            >
              {feature.title}
            </h3>

            <p class="card-desc relative text-sm leading-relaxed mb-4">
              {feature.desc}
            </p>

            {/* Animated Bottom Border */}
            <div
              class={`absolute bottom-0 left-0 h-1 bg-gradient-to-r from-transparent ${feature.gradient} to-transparent w-full transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500`}
            />
          </div>
        ))
      }
    </div>

    {/* Statistics Section - New Addition */}
    {
      stats && (
        <div class="stats-container reveal-stats flex flex-row flex-wrap justify-between items-center gap-2 sm:gap-4 md:grid md:grid-cols-3 md:gap-8 mb-12 sm:mb-20 max-w-4xl mx-auto w-full px-2">
          {stats.map((stat, i) => (
            <div class="stat-item flex-1 text-center min-w-[max-content]">
              <div
                class="stat-number text-3xl sm:text-4xl md:text-6xl font-extrabold mb-1 md:mb-2 text-gray-900"
                data-value={stat.number}
              >
                0
                <span class="stat-suffix text-xl sm:text-2xl md:text-4xl text-gray-400 font-bold ml-1">
                  {stat.suffix}
                </span>
              </div>
              <p class="stat-label text-gray-500 font-medium uppercase tracking-wider text-[10px] sm:text-xs md:text-sm">
                {stat.label}
              </p>
            </div>
          ))}
        </div>
      )
    }

    {/* CTA Button */}
    <div
      class="reveal-fade-up flex justify-center"
      style="animation-delay: 700ms;"
    >
      <Button
        url="#pricing"
        title={t["tech.partner.cta"]}
        color="primary"
        arrow
        class="group relative overflow-hidden"
      />
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initAnimations() {
    // Optional: Cleanup old triggers to avoid duplicates on re-renders
    // However, be careful not to kill triggers from other components if they share the global state
    // For this specific section, we can rely on creating new ones.

    // Header Animation (Simple Fade Up)
    const headers = gsap.utils.toArray(".reveal-fade-up");
    if (headers.length > 0) {
      gsap.fromTo(
        headers,
        { y: 50, autoAlpha: 0 },
        {
          y: 0,
          autoAlpha: 1,
          duration: 1,
          stagger: 0.1,
          ease: "power3.out",
          scrollTrigger: {
            trigger: ".tech-section",
            start: "top 75%",
            toggleActions: "play none none none",
            once: true,
          },
        },
      );
    }

    // Grid Assembly Animation (Requested)
    // Use the specific tech-grid class to ensure we target the right container
    const grid = document.querySelector(".tech-grid");
    // Select cards ONLY within this grid to avoid selecting cards from other sections/modals
    const cards = grid ? grid.querySelectorAll(".feature-card") : [];

    if (grid && cards.length > 0) {
      // Ensure cards are hidden initially and scaled down (only for the first reveal)
      gsap.set(cards, { autoAlpha: 0, scale: 0.8 });

      ScrollTrigger.create({
        trigger: ".tech-section",
        start: "top 80%",
        toggleActions: "play none none none",
        once: true,
        onEnter: () => {
          gsap.to(cards, {
            x: 0,
            y: 0,
            scale: 1,
            autoAlpha: 1,
            duration: 1,
            ease: "back.out(1.2)",
            stagger: 0.15,
          });
        },
      });

      // Set initial positions (from) safely
      const cardArray = gsap.utils.toArray(cards) as HTMLElement[];

      if (cardArray[0]) gsap.set(cardArray[0], { x: -100 });
      if (cardArray[1]) gsap.set(cardArray[1], { y: 100 });
      if (cardArray[2]) gsap.set(cardArray[2], { x: 100 });
      if (cardArray[3]) gsap.set(cardArray[3], { y: -100 });
    }

    // Stats Counter Animation
    const statsContainer = document.querySelector(".reveal-stats");
    if (statsContainer) {
      const numbers = statsContainer.querySelectorAll(".stat-number");

      ScrollTrigger.create({
        trigger: statsContainer,
        start: "top 85%",
        once: true,
        onEnter: () => {
          numbers.forEach((num) => {
            // Extract numeric value, removing non-numeric chars if any (though data-value should be clean)
            // The raw text might have spans, so we use data-value
            const finalValue = parseInt(
              num.getAttribute("data-value") || "0",
              10,
            );
            const suffixInfo = num.querySelector(".stat-suffix");
            const suffixHTML = suffixInfo ? suffixInfo.outerHTML : "";

            // Create a proxy object to animate
            const proxy = { val: 0 };

            gsap.to(proxy, {
              val: finalValue,
              duration: 2.5,
              ease: "power2.out",
              onUpdate: () => {
                // Update text content but keep the suffix span
                // We need to be careful not to overwrite the span if it was inside.
                // Actually, the structure is: [text node "0"][span suffix]
                // We can clear HTML and rebuild it
                num.innerHTML = `${Math.floor(proxy.val)}${suffixHTML}`;
              },
            });
          });

          gsap.fromTo(
            statsContainer,
            { y: 30, autoAlpha: 0 },
            { y: 0, autoAlpha: 1, duration: 1, ease: "power3.out" },
          );
        },
      });
    }
  }

  // Run on load
  initAnimations();

  // Handle Astro View Transitions
  document.addEventListener("astro:page-load", initAnimations);
</script>

<style>
  /* ─── Robust Theme Styles ─── */

  /* BASE LIGHT MODE (Default) */
  .tech-section {
    background-color: #ffffff;
    /* Ensure overflow doesn't clip the flying cards if they go out bounds temporarily */
    overflow: visible;
  }

  /* Initial state: managed by GSAP autoAlpha, but good to have fallback */
  .feature-card {
    /* Visible por defecto; GSAP controla opacidad/transform para la animación de entrada */
  }

  .section-title {
    color: #111827; /* gray-900 */
  }

  .section-desc {
    color: #4b5563; /* gray-600 */
  }

  .section-title :global(.highlight-text) {
    color: #9333ea; /* purple-600 */
  }

  .badge-tech {
    background-color: #f3e8ff; /* purple-50 */
    color: #9333ea; /* purple-600 */
    border: 1px solid #e9d5ff; /* purple-100 */
  }

  .tech-glow {
    display: none; /* ESCONDIDO EN MODO CLARO POR DEFECTO */
    background-color: rgba(88, 28, 135, 0.2); /* purple-900/20 */
  }

  .circuit-pattern {
    opacity: 0.03;
  }

  /* Cards Light Mode */
  .feature-card {
    background-color: #ffffff;
    border-color: #f3f4f6; /* gray-100 */
  }

  .feature-card:hover {
    box-shadow: 0 25px 50px -12px rgba(168, 85, 247, 0.15); /* purple shadow */
  }

  .card-title {
    color: #111827;
  }

  .card-desc {
    color: #4b5563;
  }

  /* Gradient Overlay Light Mode */
  .overlay-gradient {
    background: linear-gradient(
      to bottom right,
      rgba(255, 255, 255, 0.8),
      transparent
    );
  }

  /* Feature Colors Light Mode */
  .feature-purple {
    color: #9333ea;
  }
  .feature-bg-purple {
    background-color: #f3e8ff;
  }

  .feature-blue {
    color: #2563eb;
  }
  .feature-bg-blue {
    background-color: #dbeafe;
  }

  .feature-cyan {
    color: #0891b2;
  }
  .feature-bg-cyan {
    background-color: #cffafe;
  }

  .feature-green {
    color: #16a34a;
  }
  .feature-bg-green {
    background-color: #dcfce7;
  }

  /* Stats Styling */
  .stat-number {
    /* Gradient handled by tailwind classes in HTML, but fallback color here */
    /* color: #9333ea; removed */
  }

  /* ─── DARK MODE OVERRIDES ([data-theme="dark"]) ─── */

  :global([data-theme="dark"]) .tech-section {
    background-color: var(--color-bg); /* Use global theme bg */
  }

  :global([data-theme="dark"]) .section-title {
    color: #ffffff;
  }

  :global([data-theme="dark"]) .section-desc {
    color: #d1d5db; /* gray-300 */
  }

  :global([data-theme="dark"]) .section-title :global(.highlight-text) {
    color: #c084fc; /* purple-400 */
  }

  :global([data-theme="dark"]) .badge-tech {
    background-color: rgba(255, 255, 255, 0.05);
    color: #d8b4fe; /* purple-300 */
    border-color: rgba(255, 255, 255, 0.1);
  }

  :global([data-theme="dark"]) .tech-glow {
    display: block; /* VISIBLE SOLO EN MODO OSCURO */
  }

  :global([data-theme="dark"]) .circuit-pattern {
    opacity: 0.06;
  }

  /* Cards Dark Mode */
  :global([data-theme="dark"]) .feature-card {
    background-color: var(--color-bg-alt);
    border-color: rgba(255, 255, 255, 0.1); /* white/10 */
  }

  :global([data-theme="dark"]) .feature-card:hover {
    box-shadow: 0 25px 50px -12px rgba(88, 28, 135, 0.3); /* purple-900 shadow */
  }

  :global([data-theme="dark"]) .card-title {
    color: #ffffff;
  }

  :global([data-theme="dark"]) .card-desc {
    color: #9ca3af; /* gray-400 */
  }

  /* Gradient Overlay Dark Mode */
  :global([data-theme="dark"]) .overlay-gradient {
    background: linear-gradient(
      to bottom right,
      rgba(255, 255, 255, 0.05),
      transparent
    );
  }

  /* Feature Colors Dark Mode */
  :global([data-theme="dark"]) .feature-purple {
    color: #c084fc;
  }
  :global([data-theme="dark"]) .feature-bg-purple {
    background-color: rgba(88, 28, 135, 0.3);
  }

  :global([data-theme="dark"]) .feature-blue {
    color: #60a5fa;
  }
  :global([data-theme="dark"]) .feature-bg-blue {
    background-color: rgba(30, 58, 138, 0.3);
  }

  :global([data-theme="dark"]) .feature-cyan {
    color: #22d3ee;
  }
  :global([data-theme="dark"]) .feature-bg-cyan {
    background-color: rgba(22, 78, 99, 0.3);
  }

  :global([data-theme="dark"]) .feature-green {
    color: #4ade80;
  }
  :global([data-theme="dark"]) .feature-bg-green {
    background-color: rgba(20, 83, 45, 0.3);
  }

  :global([data-theme="dark"]) .stat-number {
    /* Using bg-clip-text in HTML but ensuring visibility */
    color: #ffffff;
    text-shadow: 0 0 20px rgba(139, 92, 246, 0.3);
  }

  :global([data-theme="dark"]) .stat-suffix {
    color: #6b7280; /* gray-500 */
  }

  .ease-spring {
    transition-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1);
  }
</style>
