---
interface Testimonial {
  name: string;
  role: string;
  business: string;
  content: string;
  avatar?: string;
}

interface Props {
  title: string;
  testimonials: Testimonial[];
}

const { title, testimonials } = Astro.props;
---

<section class="testimonials-section">
  <div class="u-container">
    <h2 class="u-heading title sy-kinetic-heading" data-sy-reveal="" set:html={title} />

    <div class="testimonials-grid">
      {testimonials.map((testimonial, index) => (
        <div class="testimonial-card" data-sy-reveal="fade" style={`transition-delay: ${index * 0.15}s`}>
          <div class="quote-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
              <path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/>
            </svg>
          </div>
          
          <p class="u-text testimonial-content">{testimonial.content}</p>
          
          <div class="testimonial-author">
            <div class="author-avatar">
              {testimonial.avatar ? (
                <img src={testimonial.avatar} alt={testimonial.name} />
              ) : (
                <div class="avatar-placeholder">
                  {testimonial.name.charAt(0)}
                </div>
              )}
            </div>
            <div class="author-info">
              <p class="u-text author-name">{testimonial.name}</p>
              <p class="u-text author-role">{testimonial.role}</p>
              <p class="u-text author-business">{testimonial.business}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials-section {
    position: relative;
    padding: 6rem 0;
    background: var(--color-bg-alt);

    @media (--mq-tablet) {
      padding: 4rem 0;
    }

    @media (--mq-phone) {
      padding: 3rem 0;
    }
  }

  .title {
    --fs: 3.5rem;
    --lh: 1.2;
    --fw: 700;
    text-align: center;
    margin-bottom: 4rem;
    color: var(--color-text);

    @media (--mq-tablet) {
      --fs: 3rem;
      margin-bottom: 3rem;
    }

    @media (--mq-phone) {
      --fs: 2.5rem;
      margin-bottom: 2.5rem;
    }
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2.5rem;
    max-width: 1200px;
    margin: 0 auto;

    @media (--mq-tablet) {
      gap: 2rem;
    }

    @media (--mq-phone) {
      display: flex;
      flex-direction: row;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: 1.5rem;
      padding-bottom: 1rem;
      margin-left: calc(-1 * var(--container-offset));
      margin-right: calc(-1 * var(--container-offset));
      padding-left: var(--container-offset);
      padding-right: var(--container-offset);
      scrollbar-width: thin;
      scrollbar-color: rgba(var(--rgb-text), 0.2) transparent;

      &::-webkit-scrollbar {
        height: 6px;
      }

      &::-webkit-scrollbar-track {
        background: transparent;
      }

      &::-webkit-scrollbar-thumb {
        background: rgba(var(--rgb-text), 0.2);
        border-radius: 3px;
      }
    }
  }

  .testimonial-card {
    background: var(--color-bg);
    border: 2px solid rgba(var(--rgb-text), 0.08);
    border-radius: 1rem;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    /* Entry animation is handled globally via [data-sy-reveal="fade"] */
    transition:
      border-color 0.25s var(--ease-standard),
      box-shadow 0.25s var(--ease-standard),
      transform 0.25s var(--ease-standard);

    &:hover {
      border-color: rgba(var(--rgb-cyan-accent), 0.3);
      transform: translateY(-5px);
      box-shadow: 0 12px 40px rgba(var(--rgb-text), 0.1);
    }

    @media (--mq-phone) {
      flex: 0 0 85%;
      min-width: 85%;
      max-width: 85%;
      padding: 2rem 1.5rem;
      scroll-snap-align: start;
    }
  }

  .quote-icon {
    color: var(--color-cyan);
    opacity: 0.3;
  }

  .testimonial-content {
    --fs: var(--font-size-md);
    line-height: 1.7;
    color: var(--color-text);
    flex: 1;
    font-style: italic;

    @media (--mq-phone) {
      --fs: var(--font-size-sm);
    }
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(var(--rgb-text), 0.08);
  }

  .author-avatar {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    overflow: hidden;
    background: rgba(var(--rgb-purple-accent), 0.1);

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }

  .avatar-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-purple);
    background: rgba(var(--rgb-purple-accent), 0.15);
  }

  .author-info {
    flex: 1;
  }

  .author-name {
    --fs: var(--font-size-md);
    --fw: 700;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }

  .author-role {
    --fs: var(--font-size-sm);
    color: var(--color-text-alt);
    margin-bottom: 0.125rem;
  }

  .author-business {
    --fs: var(--font-size-xs);
    color: var(--color-purple);
    font-weight: 600;
  }
</style>
