---
import type { Link } from "../types";
import Button from "./Button.astro";

interface Props {
  title: string;
  businessCta: Link;
  touristCta: Link;
  businessSubtitle?: string;
  businessDescription?: string;
  touristSubtitle?: string;
  touristDescription?: string;
}

const {
  title,
  businessCta,
  touristCta,
  businessSubtitle = "Para MiPyMEs",
  businessDescription = "Registra tu negocio turístico y accede a recomendaciones inteligentes que conectan a viajeros con tus servicios.",
  touristSubtitle = "Para Viajeros",
  touristDescription = "Descubre experiencias auténticas en Las Altas Montañas con recomendaciones personalizadas por IA.",
} = Astro.props;
---

<section class="user-segmentation">
  <div class="u-container">
    <h2 class="u-heading title sy-kinetic-heading" data-sy-reveal="" set:html={title} />

    <div class="cards-wrapper">
      <div class="segmentation-card" data-sy-reveal="fade">
        <div class="card-icon business-icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="48"
            height="48"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            <polyline points="9 22 9 12 15 12 15 22"></polyline>
          </svg>
        </div>
        <h3 class="u-text card-title">{businessSubtitle}</h3>
        <p class="u-text card-description">
          {businessDescription}
        </p>
        <Button {...businessCta} arrow class="card-cta" />
      </div>

      <div class="segmentation-card" data-sy-reveal="fade">
        <div class="card-icon tourist-icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="48"
            height="48"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path>
            <path d="M2 12h20"></path>
          </svg>
        </div>
        <h3 class="u-text card-title">{touristSubtitle}</h3>
        <p class="u-text card-description">
          {touristDescription}
        </p>
        <Button {...touristCta} arrow class="card-cta" />
      </div>
    </div>
  </div>
</section>

<style>
  .user-segmentation {
    position: relative;
    padding: 6rem 0;
    background: var(--color-bg);

    @media (--mq-tablet) {
      padding: 4rem 0;
    }

    @media (--mq-phone) {
      padding: 3rem 0;
    }
  }

  .title {
    --fs: 3.5rem;
    --lh: 1.2;
    --fw: 700;
    text-align: center;
    margin-bottom: 4rem;
    color: var(--color-text);

    @media (--mq-tablet) {
      --fs: 3rem;
      margin-bottom: 3rem;
    }

    @media (--mq-phone) {
      --fs: 2.5rem;
      margin-bottom: 2.5rem;
    }
  }

  .cards-wrapper {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
    max-width: 1000px;
    margin: 0 auto;

    @media (--mq-tablet) {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  .segmentation-card {
    background: var(--color-bg-alt);
    border: 2px solid rgba(var(--rgb-text), 0.08);
    border-radius: 1rem;
    padding: 3rem 2.5rem;
    text-align: center;
    /* Entry animation is handled globally via [data-sy-reveal="fade"] */
    transition:
      border-color 0.25s var(--ease-standard),
      box-shadow 0.25s var(--ease-standard),
      transform 0.25s var(--ease-standard);

    &:hover {
      border-color: rgba(var(--rgb-purple-accent), 0.3);
      transform: translateY(-8px);
      box-shadow: 0 12px 40px rgba(var(--rgb-text), 0.1);
    }

    @media (--mq-phone) {
      padding: 2.5rem 2rem;
    }
  }

  .card-icon {
    width: 80px;
    height: 80px;
    margin: 0 auto 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: all 0.3s var(--ease-standard);

    svg {
      width: 48px;
      height: 48px;
    }
  }

  .business-icon {
    background: rgba(var(--rgb-purple-accent), 0.1);
    color: var(--color-purple);

    .segmentation-card:hover & {
      background: rgba(var(--rgb-purple-accent), 0.15);
      transform: scale(1.1);
    }
  }

  .tourist-icon {
    background: rgba(var(--rgb-cyan-accent), 0.1);
    color: var(--color-cyan);

    .segmentation-card:hover & {
      background: rgba(var(--rgb-cyan-accent), 0.15);
      transform: scale(1.1);
    }
  }

  .card-title {
    --fs: var(--font-size-xl);
    --fw: 700;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .card-description {
    --fs: var(--font-size-md);
    line-height: 1.6;
    color: var(--color-text-alt);
    margin-bottom: 2rem;
    max-width: 28em;
    margin-left: auto;
    margin-right: auto;
  }

  .card-cta {
    margin-top: auto;
  }
</style>
