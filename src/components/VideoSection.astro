---
import laRegionVideo from "../assets/video/laRegion.mp4";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<section class="video-section">
  <div class="u-container">
    <div class="header">
      <h2 class="u-heading title" data-sy-reveal="words">{title}</h2>
      {description && (
        <p class="u-text description" data-sy-reveal="lines">{description}</p>
      )}
    </div>

    <div class="video-container" data-sy-reveal="fade">
      <video
        class="region-video"
        data-src={laRegionVideo}
        poster="/placeholder-poster.jpg"
        preload="metadata"
        controls
        playsinline
        aria-label="Video explorando la riqueza de Las Altas Montañas de Veracruz"
      >
        Tu navegador no soporta el elemento de video.
      </video>
    </div>
  </div>
</section>

<style>
  .video-section {
    position: relative;
    padding: 6rem 0;
    background: var(--color-bg);

    @media (--mq-tablet) {
      padding: 4rem 0;
    }

    @media (--mq-phone) {
      padding: 3rem 0;
    }
  }

  .header {
    text-align: center;
    margin-bottom: 3rem;

    @media (--mq-tablet) {
      margin-bottom: 2.5rem;
    }
  }

  .title {
    --fs: 3.5rem;
    --lh: 1.2;
    --fw: 700;
    color: var(--color-text);
    margin-bottom: 1rem;

    @media (--mq-tablet) {
      --fs: 3rem;
    }

    @media (--mq-phone) {
      --fs: 2.5rem;
    }
  }

  .description {
    --fs: var(--font-size-lg);
    color: var(--color-text-alt);
    max-width: 40em;
    margin: 0 auto;
    line-height: 1.6;

    @media (--mq-phone) {
      --fs: var(--font-size-md);
    }
  }

  .video-container {
    max-width: 1000px;
    margin: 0 auto;
    border-radius: 1rem;
    overflow: hidden;
    border: 2px solid rgba(var(--rgb-text), 0.08);
    background: rgba(var(--rgb-text), 0.02);
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s var(--ease-out-cubic);

    &[data-sy-reveal="fade"].is-in {
      opacity: 1;
      transform: translateY(0);
    }

    &:hover {
      border-color: rgba(var(--rgb-purple-accent), 0.2);
      box-shadow: 0 12px 40px rgba(var(--rgb-text), 0.1);
    }
  }

  .region-video {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    background: var(--color-bg-alt);

    /* Custom video controls styling */
    &::-webkit-media-controls-panel {
      background: rgba(var(--rgb-text), 0.9);
    }

    &::-webkit-media-controls-play-button,
    &::-webkit-media-controls-mute-button,
    &::-webkit-media-controls-fullscreen-button {
      filter: invert(1);
    }
  }
</style>

<script>
  // Lazy loading video with Intersection Observer
  const observerOptions = {
    root: null,
    rootMargin: '200px', // Start loading 200px before video enters viewport
    threshold: 0
  };

  const videoObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const video = entry.target as HTMLVideoElement;
        const videoSrc = video.dataset.src;
        
        if (videoSrc && !video.src) {
          video.src = videoSrc;
          video.load();
          console.log('Video loaded lazily');
        }
        
        videoObserver.unobserve(video);
      }
    });
  }, observerOptions);

  // Observe all videos with data-src attribute
  document.addEventListener('DOMContentLoaded', () => {
    const lazyVideos = document.querySelectorAll('video[data-src]');
    lazyVideos.forEach(video => {
      videoObserver.observe(video);
    });
  });
</script>
