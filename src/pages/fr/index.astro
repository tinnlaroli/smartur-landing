---
import Layout from "../../layouts/Layout.astro";
import HeroHome from "../../components/HeroHome.astro";
import Faqs from "../../components/Faqs.astro";

import VideoSection from "../../components/VideoSection.astro";

import TechnologySection from "../../components/TechnologySection.astro";
import Testimonials from "../../components/Testimonials.astro";
import About from "../../components/About.astro";
import PlansNew from "../../components/PlansNew.astro";
import FlightDivider from "../../components/FlightDivider.astro";
import ContactForm from "../../components/ContactForm.astro";
import Statements from "../../components/Statements.astro";
import { ui } from "../../i18n/ui";

const lang = "fr";
const t = ui[lang];
---

<Layout title={t["nav.home"]}>
  <section id="home">
    <HeroHome
      title={t["hero.title"]}
      subtitle={t["hero.subtitle"]}
      cta={{
        title: t["hero.cta"],
        url: "#about",
      }}
    />
  </section>

  <FlightDivider lang={lang} />

  <VideoSection
    id="region"
    title={t["video.title"]}
    description={t["video.description"]}
    lang={lang}
  />

  <section id="technology">
    <TechnologySection
      id="tecnologia-inner"
      lang={lang}
      stats={[
        {
          number: t["about.stat1.number"],
          suffix: t["about.stat1.suffix"],
          label: t["about.stat1.label"],
        },
        {
          number: t["about.stat2.number"],
          suffix: t["about.stat2.suffix"],
          label: t["about.stat2.label"],
        },
        {
          number: t["about.stat3.number"],
          suffix: t["about.stat3.suffix"],
          label: t["about.stat3.label"],
        },
      ]}
    />
  </section>

  <Statements
    items={[
      {
        title: t["statement1.title"],
        text: t["statement1.text"],
      },
      {
        title: t["statement2.title"],
        text: t["statement2.text"],
      },
      {
        title: t["statement3.title"],
        text: t["statement3.text"],
      },
    ]}
  />

  <About
    id="about"
    title={t["about.title"]}
    subtitle={t["about.subtitle"]}
    sectionLabel={t["about.sectionLabel"]}
    award={t["about.award"]}
    awardBadge={t["about.awardBadge"]}
    awardYear="2024"
    slides={[
      {
        id: "mission",
        label: t["about.mission.title"],
        text: t["about.mission.text"],
      },
      {
        id: "vision",
        label: t["about.vision.title"],
        text: t["about.vision.text"],
      },
      {
        id: "values",
        label: t["about.values.title"],
        text: t["about.values.text"],
      },
    ]}
    description={t["about.description"]}
    timelineTitle={t["timeline.title"]}
    timelineItems={[
      {
        title: t["timeline.step1.title"],
        text: t["timeline.step1.text"],
      },
      {
        title: t["timeline.step2.title"],
        text: t["timeline.step2.text"],
      },
      {
        title: t["timeline.step3.title"],
        text: t["timeline.step3.text"],
      },
      {
        title: t["timeline.step4.title"],
        text: t["timeline.step4.text"],
      },
    ]}
  />

  {/* StepsTimeline moved to About */}

  <Testimonials
    title={t["testimonials.title"]}
    testimonials={[
      {
        name: t["testimonials.item1.name"],
        role: t["testimonials.item1.role"],
        business: t["testimonials.item1.business"],
        content: t["testimonials.item1.content"],
      },
      {
        name: t["testimonials.item2.name"],
        role: t["testimonials.item2.role"],
        business: t["testimonials.item2.business"],
        content: t["testimonials.item2.content"],
      },
      {
        name: t["testimonials.item3.name"],
        role: t["testimonials.item3.role"],
        business: t["testimonials.item3.business"],
        content: t["testimonials.item3.content"],
      },
    ]}
  />

  <PlansNew
    id="pricing"
    title={t["pricing.new.title"]}
    subtitle={t["pricing.new.subtitle"]}
    showToggle={true}
    toggleMonthlyLabel={t["pricing.toggle.monthly"]}
    toggleAnnualLabel={t["pricing.toggle.annual"]}
    discountLabel={t["pricing.discount"]}
    items={[
      {
        title: t["pricing.basic.title"],
        description: t["pricing.basic.desc"],
        price: {
          monthly: 249,
          annual: Math.round(249 * 12 * 0.8),
          duration: t["pricing.basic.duration"],
        },
        link: {
          title: t["button.contact"],
          url: "#contact",
        },
        features: [
          { title: t["pricing.basic.feature1"] },
          { title: t["pricing.basic.feature2"] },
          { title: t["pricing.basic.feature3"] },
          { title: t["pricing.basic.feature4"] },
          { title: t["pricing.basic.feature5"] },
          { title: t["pricing.basic.feature6"] },
        ],
      },
      {
        title: t["pricing.enterprise.title"],
        description: t["pricing.enterprise.desc"],
        price: {
          monthly: 499,
          annual: Math.round(499 * 12 * 0.8),
          duration: t["pricing.enterprise.duration"],
        },
        link: {
          title: t["button.contact"],
          url: "#contact",
        },
        features: [
          { title: t["pricing.enterprise.feature1"] },
          { title: t["pricing.enterprise.feature2"] },
          { title: t["pricing.enterprise.feature3"] },
          { title: t["pricing.enterprise.feature4"] },
          { title: t["pricing.enterprise.feature5"] },
          { title: t["pricing.enterprise.feature6"] },
        ],
      },
    ]}
  />

  <section id="contact">
    <ContactForm lang={lang} />
    <Faqs
      title={t["faqs.title"]}
      mobileTitle={t["faqs.title"]}
      subtitle={t["faqs.subtitle"]}
      items={[
        {
          question: t["faq1.question"],
          answer: t["faq1.answer"],
        },
        {
          question: t["faq2.question"],
          answer: t["faq2.answer"],
        },
        {
          question: t["faq3.question"],
          answer: t["faq3.answer"],
        },
        {
          question: t["faq4.question"],
          answer: t["faq4.answer"],
        },
        {
          question: t["faq5.question"],
          answer: t["faq5.answer"],
        },
      ]}
    />
  </section>
</Layout>
