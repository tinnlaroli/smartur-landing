---
import Layout from "../../layouts/Layout.astro";
import HeroHome from "../../components/HeroHome.astro";
import TextMarquee from "../../components/TextMarquee.astro";
import Faqs from "../../components/Faqs.astro";
import StepsTimeline from "../../components/StepsTimeline.astro";
import Statements from "../../components/Statements.astro";
import RegionSection from "../../components/RegionSection.astro";

import About from "../../components/About.astro";
import PlansNew from "../../components/PlansNew.astro";
import UserSegmentation from "../../components/UserSegmentation.astro";
import VideoSection from "../../components/VideoSection.astro";
import Benefits from "../../components/Benefits.astro";
import Testimonials from "../../components/Testimonials.astro";
---

<Layout title="Accueil">
  <section id="home">
    <HeroHome
      title="Tourisme Intelligent pour les Hautes Montagnes"
      subtitle="SMARTUR connecte les touristes avec des expériences authentiques grâce à l'IA, en soutenant les PME de Veracruz dans leur transformation numérique."
      cta={{
        title: "Découvrir SMARTUR",
        url: "#about",
      }}
    />
  </section>

  <UserSegmentation
    title="Rejoignez le catalogue"
    businessCta={{
      title: "Enregistrer mon entreprise",
      url: "#contact",
    }}
    touristCta={{
      title: "Je suis un touriste",
      url: "#region",
    }}
  />

  <RegionSection
    title="Les Hautes Montagnes de Veracruz"
    text="Une région riche en culture, nature et traditions. Des villages magiques aux paysages montagneux impressionnants, les Hautes Montagnes offrent des expériences touristiques uniques que SMARTUR aide à découvrir et promouvoir."
  />

  <VideoSection
    title="Explorez la richesse de notre région"
    description="Découvrez la beauté naturelle et culturelle des Hautes Montagnes de Veracruz"
  />

  <section id="technology">
    <Benefits
      id="technology-inner"
      title="Pourquoi nous choisir ?"
      subtitle="Avantages d'appartenir à SMARTUR"
      benefits={[
        {
          title: "Visibilité Régionale",
          description: "Positionnez votre entreprise devant des milliers de touristes à la recherche d'expériences authentiques.",
          icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>`
        },
        {
          title: "Recommandations IA",
          description: "Algorithmes intelligents qui connectent votre entreprise aux clients idéaux.",
          icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4M12 8h.01"></path></svg>`
        },
        {
          title: "Analyse de Données",
          description: "Métriques et rapports qui vous aident à prendre des décisions éclairées.",
          icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>`
        },
        {
          title: "Support Dédié",
          description: "Équipe experte qui vous accompagne à chaque étape de votre transformation numérique.",
          icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"></path></svg>`
        },
        {
          title: "Croissance Durable",
          description: "Outils qui évoluent avec votre entreprise et renforcent l'économie locale.",
          icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>`
        },
        {
          title: "Intégration Facile",
          description: "Processus d'inscription simple et rapide pour commencer à recevoir des clients.",
          icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>`
        }
      ]}
      improvements={{
        title: "Améliorations claires avec l'IA",
        items: [
          "Augmentation moyenne de 40% des réservations pour les entreprises enregistrées",
          "Réduction de 60% du temps de recherche pour les touristes",
          "Amélioration de 85% de la satisfaction des expériences recommandées",
          "Optimisation automatique des prix selon la demande et la saison"
        ]
      }}
    />
  </section>

  <StepsTimeline
    title="Notre Parcours"
    items={[
      {
        title: "Prix du Tourisme Mi Veracruz 2024",
        text: "SMARTUR est né du manuel de procédures primé, reconnu pour son innovation dans la promotion du tourisme régional.",
      },
      {
        title: "Développement d'algorithmes d'IA",
        text: "Création d'un système de recommandation intelligent basé sur le Machine Learning, spécifiquement conçu pour le contexte touristique des Hautes Montagnes.",
      },
      {
        title: "Mise en œuvre régionale",
        text: "Déploiement de la plateforme en collaboration avec les hôtels, restaurants et commerces locaux, générant un impact réel sur l'économie touristique.",
      },
    ]}
  />

  <Statements
    items={[
      {
        title: "Innovation",
        text: "Nous utilisons l'intelligence artificielle et la technologie de pointe pour révolutionner la façon dont le tourisme est découvert et vécu dans les Hautes Montagnes.",
      },
      {
        title: "Identité Régionale",
        text: "Nous célébrons et promouvons la richesse culturelle, naturelle et gastronomique unique de Veracruz, en connectant les voyageurs avec des expériences authentiques.",
      },
      {
        title: "Durabilité Technologique",
        text: "Nous autonomisons les PME locales avec des outils numériques accessibles qui renforcent leur compétitivité et leur croissance durable.",
      },
    ]}
  />

  <Testimonials
    title="Témoignages : Que disent les services associés ?"
    testimonials={[
      {
        name: "Cha Ji-Hun",
        role: "Propriétaire",
        business: "Café Las Montañas",
        content: "Depuis que nous avons rejoint SMARTUR, nos réservations ont augmenté de 45%. La plateforme nous connecte avec des touristes qui apprécient vraiment l'expérience authentique que nous offrons."
      },
      {
        name: "María González",
        role: "Gérante",
        business: "Hôtel Vista Hermosa",
        content: "Les recommandations de l'IA sont incroyables. Nous recevons exactement le type d'invités qui recherchent ce que nous proposons. Le tableau de bord d'analyse nous aide à prendre de meilleures décisions."
      },
      {
        name: "Roberto Sánchez",
        role: "Guide Touristique",
        business: "Aventuras Veracruz",
        content: "SMARTUR a transformé mon entreprise. Je peux maintenant me concentrer sur l'offre d'expériences mémorables pendant que la plateforme s'occupe de me mettre en contact avec les bons voyageurs."
      }
    ]}
  />

  <About
    id="about"
    title="Qui Sommes-Nous"
    subtitle="Innovation technologique au service du tourisme régional"
    award="Prix du Tourisme Mi Veracruz"
    mission="Connecter les touristes avec des expériences authentiques dans les Hautes Montagnes grâce à l'intelligence artificielle qui autonomise les PME locales."
    description="Lauréat du 'Prix du Tourisme Mi Veracruz 2024', SMARTUR utilise des algorithmes avancés de Machine Learning pour offrir des recommandations personnalisées qui profitent aux voyageurs et aux entreprises locales."
    cta={{
      title: "Voir les Plans",
      url: "#pricing",
    }}
  />

  <PlansNew
    id="pricing"
    title="Des solutions conçues pour chaque acteur de l'écosystème touristique"
    subtitle="Des plans flexibles qui s'adaptent à vos besoins"
    showToggle={true}
    items={[
      {
        title: "Entrepreneur",
        description: "Pour les petites entreprises",
        price: {
          amount: "$00",
          duration: "mois",
        },
        link: {
          title: "Enregistrer mon entreprise",
          url: "#contact",
        },
        features: [
          { title: "Segmentation d'audience" },
          { title: "Approche tourisme ciblé" },
          { title: "Recommandations IA basiques" },
          { title: "Support par email" },
          { title: "Tableau de bord basique" },
          { title: "Analyses avancées", disabled: true },
        ],
      },
      {
        title: "Destination",
        description: "Pour organisations et gouvernements",
        price: {
          amount: "$00",
          duration: "mois",
        },
        link: {
          title: "Planifier une démo",
          url: "#contact",
        },
        features: [
          { title: "Tout dans Entrepreneur, plus:" },
          { title: "Rapports avancés" },
          { title: "Tableau de bord décisionnel" },
          { title: "Analyses prédictives" },
          { title: "Support prioritaire" },
          { title: "Intégration avec les systèmes" },
        ],
      },
    ]}
  />

  <TextMarquee
    class="marquee"
    texts={[
      "Tourisme Intelligent",
      "Innovation Régionale",
      "IA pour les PME",
      "Les Hautes Montagnes",
    ]}
  />

  <section id="contact">
    <Faqs
    title="FAQ"
    mobileTitle="FAQ"
    subtitle="Réponses à vos questions sur SMARTUR"
    items={[
      {
        question: "Qu'est-ce que SMARTUR?",
        answer:
          "SMARTUR est une plateforme de recommandation touristique intelligente qui utilise l'IA pour connecter les voyageurs avec des expériences authentiques dans les Hautes Montagnes de Veracruz, tout en soutenant les PME locales.",
      },
      {
        question: "Comment fonctionne le système de recommandations?",
        answer:
          "Nous utilisons des algorithmes de Machine Learning qui analysent les préférences, les comportements et les contextes pour générer des suggestions personnalisées d'hôtels, restaurants et activités touristiques.",
      },
      {
        question: "Est-ce gratuit pour les entreprises locales?",
        answer:
          "SMARTUR propose des plans accessibles spécifiquement conçus pour les PME, avec des options qui s'adaptent à différents besoins et budgets.",
      },
      {
        question: "Mes données sont-elles sécurisées?",
        answer:
          "Oui. Nous mettons en œuvre des normes de sécurité et de confidentialité de classe mondiale pour protéger toutes les informations des utilisateurs et des entreprises.",
      },
      {
        question: "Comment puis-je intégrer mon entreprise dans SMARTUR?",
        answer:
          "Contactez-nous via le formulaire sur notre page. Notre équipe vous guidera dans le processus d'inscription et de configuration de votre profil d'entreprise.",
      },
    ]}
  />

</Layout>

<style>
  .marquee {
    padding: 2rem 0;
    z-index: 9;
  }
</style>
