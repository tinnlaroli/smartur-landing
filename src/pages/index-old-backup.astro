---
import Layout from "../layouts/Layout.astro";
import HeroHome from "../components/HeroHome.astro";
import TextMarquee from "../components/TextMarquee.astro";
import Faqs from "../components/Faqs.astro";
import StepsTimeline from "../components/StepsTimeline.astro";
import Statements from "../components/Statements.astro";
import Introducing from "../components/Introducing.astro";
import RegionSection from "../components/RegionSection.astro";
import TechnologySection from "../components/TechnologySection.astro";
import About from "../components/About.astro";
import Plans from "../components/Plans.astro";
---

<Layout title="Inicio">
  <section id="inicio">
    <HeroHome
      title="IA que guía, turismo que une."
      subtitle="SMARTUR conecta turistas con experiencias auténticas mediante IA, impulsando a las MiPyMEs de Veracruz en su transformación digital."
      cta={{
        title: "Descubre SMARTUR",
        url: "#nosotros",
      }}
    />
  </section>



  <RegionSection
    title="Las Altas Montañas de Veracruz"
    text="Una región rica en cultura, naturaleza y tradiciones. Desde pueblos mágicos hasta paisajes montañosos impresionantes, Las Altas Montañas ofrece experiencias turísticas únicas que SMARTUR ayuda a descubrir y promover."
  />

  <section id="tecnologia">
    <TechnologySection
      title="Tecnología que impulsa el turismo"
      text="SMARTUR utiliza algoritmos de Machine Learning para analizar preferencias, comportamientos y contextos, generando recomendaciones turísticas personalizadas que benefician tanto a viajeros como a negocios locales."
      features={[
      {
        title: "Recomendaciones Personalizadas",
        description:
          "Algoritmos de IA que aprenden de las preferencias de cada usuario para sugerir experiencias únicas y relevantes.",
      },
      {
        title: "Apoyo a MiPyMEs",
        description:
          "Visibilidad y promoción para pequeños y medianos negocios turísticos de la región.",
      },
      {
        title: "Datos Seguros",
        description:
          "Protección de información con estándares de seguridad y privacidad de clase mundial.",
      },
    ]}
  />

  <StepsTimeline
    title="Nuestro camino"
    items={[
      {
        title: "Galardón Turístico Mi Veracruz 2024",
        text: "SMARTUR nace del manual de procedimientos galardonado, reconocido por su innovación en la promoción del turismo regional.",
      },
      {
        title: "Desarrollo de algoritmos de IA",
        text: "Creación de un sistema de recomendaciones inteligente basado en Machine Learning, diseñado específicamente para el contexto turístico de Las Altas Montañas.",
      },
      {
        title: "Implementación regional",
        text: "Despliegue de la plataforma en colaboración con hoteles, restaurantes y comercios locales, generando impacto real en la economía turística.",
      },
    ]}
  />

  <Statements
    items={[
      {
        title: "Innovación",
        text: "Utilizamos inteligencia artificial y tecnología de vanguardia para revolucionar la forma en que se descubre y experimenta el turismo en Las Altas Montañas.",
      },
      {
        title: "Identidad Regional",
        text: "Celebramos y promovemos la riqueza cultural, natural y gastronómica única de Veracruz, conectando a viajeros con experiencias auténticas.",
      },
      {
        title: "Sostenibilidad Tecnológica",
        text: "Empoderamos a las MiPyMEs locales con herramientas digitales accesibles que fortalecen su competitividad y crecimiento sostenible.",
      },
    ]}
  />

  <About
    title="Quiénes Somos"
    subtitle="Innovación tecnológica al servicio del turismo regional"
    award="Galardón Turístico Mi Veracruz"
    mission="Conectar turistas con experiencias auténticas en Las Altas Montañas mediante inteligencia artificial que empodera a las MiPyMEs locales."
    description="Galardonados con el 'Galardón Turístico Mi Veracruz 2024', SMARTUR utiliza algoritmos avanzados de Machine Learning para ofrecer recomendaciones personalizadas que benefician tanto a viajeros como a negocios locales."
    cta={{
      title: "Ver Planes",
      url: "#pricing",
    }}
  />

  <Plans
    id="pricing"
    title="Planes SMARTUR"
    subtitle="Soluciones para MiPyMEs turísticas"
    items={[
      {
        title: "Básico",
        price: {
          amount: "$499",
          duration: "mes",
        },
        link: {
          title: "Comenzar",
          url: "#contacto",
        },
        features: [
          { title: "Perfil de negocio básico" },
          { title: "Hasta 10 fotos" },
          { title: "Recomendaciones IA" },
          { title: "Soporte por email" },
          { title: "Análisis avanzado", disabled: true },
          { title: "Promociones destacadas", disabled: true },
        ],
      },
      {
        title: "MiPyME",
        price: {
          amount: "$999",
          duration: "mes",
        },
        link: {
          title: "Comenzar",
          url: "#contacto",
        },
        features: [
          { title: "Perfil de negocio completo" },
          { title: "Fotos ilimitadas" },
          { title: "Recomendaciones IA prioritarias" },
          { title: "Soporte prioritario" },
          { title: "Análisis y métricas" },
          { title: "Promociones destacadas" },
        ],
      },
      {
        title: "Enterprise",
        price: {
          amount: "$1,999",
          duration: "mes",
        },
        link: {
          title: "Contactar",
          url: "#contacto",
        },
        features: [
          { title: "Todo en MiPyME, más:" },
          { title: "Múltiples ubicaciones" },
          { title: "API personalizada" },
          { title: "Gerente de cuenta dedicado" },
          { title: "Integración con sistemas" },
          { title: "Reportes personalizados" },
        ],
      },
    ]}
  />

  <TextMarquee
    class="marquee"
    texts={[
      "Turismo Inteligente",
      "Innovación Regional",
      "IA para MiPyMEs",
      "Las Altas Montañas",
    ]}
  />

  <section id="contacto">
    <Faqs
    title="FAQs"
    mobileTitle="FAQs"
    subtitle="Respuestas a tus dudas sobre SMARTUR"
    items={[
      {
        question: "¿Qué es SMARTUR?",
        answer:
          "SMARTUR es una plataforma de recomendación turística inteligente que utiliza IA para conectar a viajeros con experiencias auténticas en Las Altas Montañas de Veracruz, mientras apoya a las MiPyMEs locales.",
      },
      {
        question: "¿Cómo funciona el sistema de recomendaciones?",
        answer:
          "Utilizamos algoritmos de Machine Learning que analizan preferencias, comportamientos y contextos para generar sugerencias personalizadas de hoteles, restaurantes y actividades turísticas.",
      },
      {
        question: "¿Es gratuito para los negocios locales?",
        answer:
          "SMARTUR ofrece planes accesibles diseñados específicamente para MiPyMEs, con opciones que se adaptan a diferentes necesidades y presupuestos.",
      },
      {
        question: "¿Mis datos están seguros?",
        answer:
          "Sí. Implementamos estándares de seguridad y privacidad de clase mundial para proteger toda la información de usuarios y negocios.",
      },
      {
        question: "¿Cómo puedo integrar mi negocio a SMARTUR?",
        answer:
          "Contáctanos a través del formulario en nuestra página. Nuestro equipo te guiará en el proceso de registro y configuración de tu perfil empresarial.",
      },
    ]}
  />

</Layout>

<style>
  .marquee {
    padding: 2rem 0;
    z-index: 9;
  }
</style>
