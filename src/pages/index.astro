---
import Layout from "../layouts/Layout.astro";
import HeroHome from "../components/HeroHome.astro";
import Faqs from "../components/Faqs.astro";
import StepsTimeline from "../components/StepsTimeline.astro";
import VideoSection from "../components/VideoSection.astro";

import TechnologySection from "../components/TechnologySection.astro";
import Testimonials from "../components/Testimonials.astro";
import About from "../components/About.astro";
import PlansNew from "../components/PlansNew.astro";
import FlightDivider from "../components/FlightDivider.astro";
import ContactForm from "../components/ContactForm.astro";
import Statements from "../components/Statements.astro";
import { ui, defaultLang } from "../i18n/ui";
---

<Layout title="Inicio">
  <section id="inicio">
    <HeroHome
      title={ui.es["hero.title"]}
      subtitle={ui.es["hero.subtitle"]}
      cta={{
        title: ui.es["hero.cta"],
        url: "#nosotros",
      }}
    />
  </section>

  <FlightDivider lang="es" />

  <VideoSection
    id="region"
    title={ui.es["video.title"]}
    description={ui.es["video.description"]}
  />

  <section id="tecnologia">
    <TechnologySection id="tecnologia-inner" lang="es" />
  </section>

  <Statements
    items={[
      {
        title: ui.es["statement1.title"],
        text: ui.es["statement1.text"],
      },
      {
        title: ui.es["statement2.title"],
        text: ui.es["statement2.text"],
      },
      {
        title: ui.es["statement3.title"],
        text: ui.es["statement3.text"],
      },
    ]}
  />

  <About
    id="nosotros"
    title={ui.es["about.title"]}
    subtitle={ui.es["about.subtitle"]}
    sectionLabel={ui.es["about.sectionLabel"]}
    award={ui.es["about.award"]}
    awardBadge={ui.es["about.awardBadge"]}
    awardYear="2024"
    slides={[
      {
        id: "mission",
        label: ui.es["about.mission.title"],
        text: ui.es["about.mission.text"],
      },
      {
        id: "vision",
        label: ui.es["about.vision.title"],
        text: ui.es["about.vision.text"],
      },
      {
        id: "values",
        label: ui.es["about.values.title"],
        text: ui.es["about.values.text"],
      },
    ]}
    description={ui.es["about.description"]}
    stats={[
      { number: ui.es["about.stat1.number"], suffix: ui.es["about.stat1.suffix"], label: ui.es["about.stat1.label"] },
      { number: ui.es["about.stat2.number"], suffix: ui.es["about.stat2.suffix"], label: ui.es["about.stat2.label"] },
      { number: ui.es["about.stat3.number"], suffix: ui.es["about.stat3.suffix"], label: ui.es["about.stat3.label"] },
    ]}

  />

  <StepsTimeline
    title={ui.es["timeline.title"]}
    items={[
      {
        title: ui.es["timeline.step1.title"],
        text: ui.es["timeline.step1.text"],
      },
      {
        title: ui.es["timeline.step2.title"],
        text: ui.es["timeline.step2.text"],
      },
      {
        title: ui.es["timeline.step3.title"],
        text: ui.es["timeline.step3.text"],
      },
    ]}
  />



  <Testimonials
    title={ui.es["testimonials.title"]}
    testimonials={[
      {
        name: ui.es["testimonials.item1.name"],
        role: ui.es["testimonials.item1.role"],
        business: ui.es["testimonials.item1.business"],
        content: ui.es["testimonials.item1.content"],
      },
      {
        name: ui.es["testimonials.item2.name"],
        role: ui.es["testimonials.item2.role"],
        business: ui.es["testimonials.item2.business"],
        content: ui.es["testimonials.item2.content"],
      },
      {
        name: ui.es["testimonials.item3.name"],
        role: ui.es["testimonials.item3.role"],
        business: ui.es["testimonials.item3.business"],
        content: ui.es["testimonials.item3.content"],
      },
    ]}
  />

  <PlansNew
    id="pricing"
    title={ui[defaultLang]["pricing.new.title"]}
    subtitle={ui[defaultLang]["pricing.new.subtitle"]}
    showToggle={true}
    toggleMonthlyLabel={ui[defaultLang]["pricing.toggle.monthly"]}
    toggleAnnualLabel={ui[defaultLang]["pricing.toggle.annual"]}
    discountLabel={ui[defaultLang]["pricing.discount"]}
    items={[
      {
        title: ui[defaultLang]["pricing.basic.title"],
        description: ui[defaultLang]["pricing.basic.desc"],
        price: {
          monthly: 249,
          annual: Math.round(249 * 12 * 0.8),
          duration: ui[defaultLang]["pricing.basic.duration"],
        },
        link: {
          title: ui[defaultLang]["button.contact"],
          url: "#contacto",
        },
        features: [
          { title: ui[defaultLang]["pricing.basic.feature1"] },
          { title: ui[defaultLang]["pricing.basic.feature2"] },
          { title: ui[defaultLang]["pricing.basic.feature3"] },
          { title: ui[defaultLang]["pricing.basic.feature4"] },
        ],
      },
      {
        title: ui[defaultLang]["pricing.enterprise.title"],
        description: ui[defaultLang]["pricing.enterprise.desc"],
        price: {
          monthly: 499,
          annual: Math.round(499 * 12 * 0.8),
          duration: ui[defaultLang]["pricing.enterprise.duration"],
        },
        link: {
          title: ui[defaultLang]["button.contact"],
          url: "#contacto",
        },
        features: [
          { title: ui[defaultLang]["pricing.enterprise.feature1"] },
          { title: ui[defaultLang]["pricing.enterprise.feature2"] },
          { title: ui[defaultLang]["pricing.enterprise.feature3"] },
          { title: ui[defaultLang]["pricing.enterprise.feature4"] },
          { title: ui[defaultLang]["pricing.enterprise.feature5"] },
        ],
      }
    ]}
  />

  <section id="contacto">
    <ContactForm lang="es" />
    <Faqs
      title={ui.es["faqs.title"]}
      mobileTitle={ui.es["faqs.title"]}
      subtitle={ui.es["faqs.subtitle"]}
      items={[
        {
          question: ui.es["faq1.question"],
          answer: ui.es["faq1.answer"],
        },
        {
          question: ui.es["faq2.question"],
          answer: ui.es["faq2.answer"],
        },
        {
          question: ui.es["faq3.question"],
          answer: ui.es["faq3.answer"],
        },
        {
          question: ui.es["faq4.question"],
          answer: ui.es["faq4.answer"],
        },
        {
          question: ui.es["faq5.question"],
          answer: ui.es["faq5.answer"],
        },
      ]}
    />
  </section>
</Layout>
