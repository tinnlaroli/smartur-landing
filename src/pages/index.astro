---
import Layout from "../layouts/Layout.astro";
import HeroHome from "../components/HeroHome.astro";
import UserSegmentation from "../components/UserSegmentation.astro";
import TextMarquee from "../components/TextMarquee.astro";
import Faqs from "../components/Faqs.astro";
import StepsTimeline from "../components/StepsTimeline.astro";
import Statements from "../components/Statements.astro";
import Introducing from "../components/Introducing.astro";
import RegionSection from "../components/RegionSection.astro";
import VideoSection from "../components/VideoSection.astro";

import Benefits from "../components/Benefits.astro";
import Testimonials from "../components/Testimonials.astro";
import About from "../components/About.astro";
import PlansNew from "../components/PlansNew.astro";
---

<Layout title="Inicio">
  <section id="inicio">
    <HeroHome
      title={`IA que <span style="color: var(--color-purple)">guía,</span><br><span style="color: var(--color-cyan)">turismo</span> que une.`}
      subtitle="SMARTUR conecta turistas con experiencias auténticas mediante IA, impulsando a las MiPyMEs de Veracruz en su transformación digital."
      cta={{
        title: "Descubre SMARTUR",
        url: "#nosotros",
      }}
    />
  </section>

  <UserSegmentation
    title="Forma parte del catálogo"
    businessCta={{
      title: "Registrar mi negocio",
      url: "#contacto",
    }}
    touristCta={{
      title: "Soy turista",
      url: "#region",
    }}
  />

  <RegionSection
    title="Las Altas Montañas de Veracruz"
    text="Una región rica en cultura, naturaleza y tradiciones. Desde pueblos mágicos hasta paisajes montañosos impresionantes, Las Altas Montañas ofrece experiencias turísticas únicas que SMARTUR ayuda a descubrir y promover."
  />

  <VideoSection
    title="Explora la riqueza de nuestra región"
    description="Descubre la belleza natural y cultural de Las Altas Montañas de Veracruz"
  />

  <section id="tecnologia">
    <Benefits
      id="tecnologia-inner" 
      title="¿Por qué elegirnos?"
      subtitle="Beneficios de pertenecer a SMARTUR"
      benefits={[
        {
          title: "Visibilidad Regional",
          description: "Posiciona tu negocio frente a miles de turistas que buscan experiencias auténticas.",
          icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>`
        },
        {
          title: "Recomendaciones IA",
          description: "Algoritmos inteligentes que conectan tu negocio con los clientes ideales.",
          icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4M12 8h.01"></path></svg>`
        },
        {
          title: "Análisis de Datos",
          description: "Métricas y reportes que te ayudan a tomar decisiones informadas.",
          icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>`
        },
        {
          title: "Soporte Dedicado",
          description: "Equipo experto que te acompaña en cada paso de tu transformación digital.",
          icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"></path></svg>`
        },
        {
          title: "Crecimiento Sostenible",
          description: "Herramientas que escalan con tu negocio y fortalecen la economía local.",
          icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>`
        },
        {
          title: "Integración Fácil",
          description: "Proceso de registro simple y rápido para empezar a recibir clientes.",
          icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>`
        }
      ]}
      improvements={{
        title: "Mejoras claras con IA",
        items: [
          "Incremento promedio del 40% en reservas para negocios registrados",
          "Reducción del 60% en tiempo de búsqueda para turistas",
          "Mejora del 85% en satisfacción de experiencias recomendadas",
          "Optimización automática de precios según demanda y temporada"
        ]
      }}
    />
  </section>

  <StepsTimeline
    title="Nuestro camino"
    items={[
      {
        title: "Galardón Turístico Mi Veracruz 2024",
        text: "SMARTUR nace del manual de procedimientos galardonado, reconocido por su innovación en la promoción del turismo regional.",
      },
      {
        title: "Desarrollo de algoritmos de IA",
        text: "Creación de un sistema de recomendaciones inteligente basado en Machine Learning, diseñado específicamente para el contexto turístico de Las Altas Montañas.",
      },
      {
        title: "Implementación regional",
        text: "Despliegue de la plataforma en colaboración con hoteles, restaurantes y comercios locales, generando impacto real en la economía turística.",
      },
    ]}
  />

  <Statements
    items={[
      {
        title: "Innovación",
        text: "Utilizamos inteligencia artificial y tecnología de vanguardia para revolucionar la forma en que se descubre y experimenta el turismo en Las Altas Montañas.",
      },
      {
        title: "Identidad Regional",
        text: "Celebramos y promovemos la riqueza cultural, natural y gastronómica única de Veracruz, conectando a viajeros con experiencias auténticas.",
      },
      {
        title: "Sostenibilidad Tecnológica",
        text: "Empoderamos a las MiPyMEs locales con herramientas digitales accesibles que fortalecen su competitividad y crecimiento sostenible.",
      },
    ]}
  />

  <Testimonials
    title="Testimonios: ¿Qué dicen los servicios asociados?"
    testimonials={[
      {
        name: "Cha Ji-Hun",
        role: "Propietario",
        business: "Café Las Montañas",
        content: "Desde que nos unimos a SMARTUR, nuestras reservas aumentaron un 45%. La plataforma nos conecta con turistas que realmente valoran la experiencia auténtica que ofrecemos."
      },
      {
        name: "María González",
        role: "Gerente",
        business: "Hotel Vista Hermosa",
        content: "Las recomendaciones de IA son increíbles. Recibimos exactamente el tipo de huéspedes que buscan lo que ofrecemos. El dashboard de análisis nos ayuda a tomar mejores decisiones."
      },
      {
        name: "Roberto Sánchez",
        role: "Guía Turístico",
        business: "Aventuras Veracruz",
        content: "SMARTUR transformó mi negocio. Ahora puedo enfocarme en ofrecer experiencias memorables mientras la plataforma se encarga de conectarme con los viajeros adecuados."
      }
    ]}
  />

  <About
    id="nosotros"
    title="Quiénes Somos"
    subtitle="Innovación tecnológica al servicio del turismo regional"
    award="Galardón Turístico Mi Veracruz"
    mission="Conectar turistas con experiencias auténticas en Las Altas Montañas mediante inteligencia artificial que empodera a las MiPyMEs locales."
    description="Galardonados con el 'Galardón Turístico Mi Veracruz 2024', SMARTUR utiliza algoritmos avanzados de Machine Learning para ofrecer recomendaciones personalizadas que benefician tanto a viajeros como a negocios locales."
    cta={{
      title: "Ver Planes",
      url: "#pricing",
    }}
  />

  <PlansNew
    id="pricing"
    title="Soluciones diseñadas para cada actor del ecosistema turístico"
    subtitle="Planes flexibles que se adaptan a tus necesidades"
    showToggle={true}
    items={[
      {
        title: "Emprendedor",
        description: "Para negocios pequeños",
        price: {
          amount: "$00",
          duration: "mes",
        },
        link: {
          title: "Registrar mi negocio",
          url: "#contacto",
        },
        features: [
          { title: "Segmentación de audiencia" },
          { title: "Enfoque turismo focal" },
          { title: "Recomendaciones IA básicas" },
          { title: "Soporte por email" },
          { title: "Dashboard básico" },
          { title: "Análisis avanzado", disabled: true },
        ],
      },
      {
        title: "Destino",
        description: "Para Pacaemy Argentohes",
        price: {
          amount: "$00",
          duration: "mes",
        },
        link: {
          title: "Agendar demo",
          url: "#contacto",
        },
        features: [
          { title: "Todo en Emprendedor, más:" },
          { title: "Reportes avanzados" },
          { title: "Dashboard para toma de decisiones" },
          { title: "Análisis predictivo" },
          { title: "Soporte prioritario" },
          { title: "Integración con sistemas" },
        ],
      },
    ]}
  />

  <TextMarquee
    class="marquee"
    texts={[
      "Turismo Inteligente",
      "Innovación Regional",
      "IA para MiPyMEs",
      "Las Altas Montañas",
    ]}
  />

  <section id="contacto">
    <Faqs
    title="FAQs"
    mobileTitle="FAQs"
    subtitle="Respuestas a tus dudas sobre SMARTUR"
    items={[
      {
        question: "¿Qué es SMARTUR?",
        answer:
          "SMARTUR es una plataforma de recomendación turística inteligente que utiliza IA para conectar a viajeros con experiencias auténticas en Las Altas Montañas de Veracruz, mientras apoya a las MiPyMEs locales.",
      },
      {
        question: "¿Cómo funciona el sistema de recomendaciones?",
        answer:
          "Utilizamos algoritmos de Machine Learning que analizan preferencias, comportamientos y contextos para generar sugerencias personalizadas de hoteles, restaurantes y actividades turísticas.",
      },
      {
        question: "¿Es gratuito para los negocios locales?",
        answer:
          "SMARTUR ofrece planes accesibles diseñados específicamente para MiPyMEs, con opciones que se adaptan a diferentes necesidades y presupuestos.",
      },
      {
        question: "¿Mis datos están seguros?",
        answer:
          "Sí. Implementamos estándares de seguridad y privacidad de clase mundial para proteger toda la información de usuarios y negocios.",
      },
      {
        question: "¿Cómo puedo integrar mi negocio a SMARTUR?",
        answer:
          "Contáctanos a través del formulario en nuestra página. Nuestro equipo te guiará en el proceso de registro y configuración de tu perfil empresarial.",
      },
    ]}
  />

</Layout>

<style>
  .marquee {
    padding: 2rem 0;
    z-index: 9;
  }
</style>
